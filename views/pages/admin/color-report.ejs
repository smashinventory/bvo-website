<%
/**
 * Color Family Report — Task #35
 * Lists products with color_family IS NULL so they can be bulk-mapped.
 *
 * Locals:
 *   unmappedColors   — [{color, category_name, category_id, product_count}]
 *   nullColorCount   — int (products with no color string at all)
 *   families         — FAMILIES array from colorFamilies.js
 *   existingMappings — [{vendor_color, context, family_key, notes}]
 *   flash            — {type, msg} | null
 */
var cabinetFamilies = families.filter(function(f) { return f.type === 'cabinet'; });
var metalFamilies   = families.filter(function(f) { return f.type === 'metal';   });
var totalUnmapped   = unmappedColors.reduce(function(s, r) { return s + r.product_count; }, 0);
%>

<% if (locals.flash) { %>
<div class="adm-flash adm-flash--<%= flash.type %>" style="margin-bottom:16px"><%- flash.msg %></div>
<% } %>

<!-- ══ Summary cards ══════════════════════════════════════════════════ -->
<div class="adm-stats-grid" style="margin-bottom:24px">
  <div class="adm-stat-card">
    <div class="adm-stat-icon" style="background:#e8f0fe">
      <svg viewBox="0 0 24 24" fill="none" stroke="#3b5bdb" stroke-width="2"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="4"/><line x1="4.93" y1="4.93" x2="9.17" y2="9.17"/><line x1="14.83" y1="14.83" x2="19.07" y2="19.07"/><line x1="14.83" y1="9.17" x2="19.07" y2="4.93"/><line x1="4.93" y1="19.07" x2="9.17" y2="14.83"/></svg>
    </div>
    <div>
      <p class="adm-stat-label">Unmapped Vendor Colors</p>
      <p class="adm-stat-value"><%= unmappedColors.length %></p>
      <p class="adm-stat-sub"><%= totalUnmapped.toLocaleString() %> products affected</p>
    </div>
  </div>
  <div class="adm-stat-card">
    <div class="adm-stat-icon" style="background:#fff3cd">
      <svg viewBox="0 0 24 24" fill="none" stroke="#b8860b" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
    </div>
    <div>
      <p class="adm-stat-label">No Color String (manual fix)</p>
      <p class="adm-stat-value"><%= nullColorCount.toLocaleString() %></p>
      <p class="adm-stat-sub">requires product-level edit</p>
    </div>
  </div>
  <div class="adm-stat-card">
    <div class="adm-stat-icon" style="background:#d4edda">
      <svg viewBox="0 0 24 24" fill="none" stroke="#2a7a3b" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
    </div>
    <div>
      <p class="adm-stat-label">Saved Mappings</p>
      <p class="adm-stat-value"><%= existingMappings.length %></p>
      <p class="adm-stat-sub">in color_mappings table</p>
    </div>
  </div>
</div>

<% if (unmappedColors.length === 0) { %>
<div class="adm-empty" style="margin-top:32px">
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="48" height="48"><polyline points="20 6 9 17 4 12"/></svg>
  <p>All products have a color family assigned.</p>
  <% if (nullColorCount > 0) { %>
  <p style="font-size:13px;color:#888"><%= nullColorCount %> product(s) have no color string — edit those individually via the Products page.</p>
  <% } %>
</div>

<% } else { %>

<!-- ══ Unmapped vendor colors table ══════════════════════════════════ -->
<div class="adm-section-header">
  <h2 class="adm-section-title">Unmapped Vendor Colors</h2>
  <p style="font-size:13px;color:#666;margin:0">
    Select the correct BVO color family for each vendor color, then click Apply.
    This updates all matching products and saves the mapping permanently.
  </p>
</div>

<div class="adm-table-wrap" style="margin-top:12px">
  <table class="adm-table">
    <thead>
      <tr>
        <th>Vendor Color</th>
        <th>Category</th>
        <th style="text-align:center">Products</th>
        <th>Context</th>
        <th>Assign Family</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% unmappedColors.forEach(function(row) { %>
      <tr>
        <td>
          <strong><%= row.color %></strong>
        </td>
        <td style="color:#666;font-size:13px"><%= row.category_name || '—' %></td>
        <td style="text-align:center">
          <span class="adm-badge"><%= row.product_count %></span>
        </td>
        <td>
          <% /* Default context: cabinet for vanities (cat 1), metal for everything else */ %>
          <% var defaultCtx = (row.category_id === 1) ? 'cabinet' : 'metal'; %>
          <select name="_ctx_<%= row.color %>" class="adm-select adm-select--sm cr-ctx-select"
                  data-color="<%= row.color %>"
                  id="ctx_<%= row.color.replace(/[^a-zA-Z0-9]/g,'_') %>">
            <option value="cabinet" <%= defaultCtx === 'cabinet' ? 'selected' : '' %>>Cabinet</option>
            <option value="metal"   <%= defaultCtx === 'metal'   ? 'selected' : '' %>>Metal</option>
          </select>
        </td>
        <td>
          <form method="POST" action="/admin/products/color-report" class="cr-apply-form">
            <input type="hidden" name="vendor_color" value="<%= row.color %>">
            <input type="hidden" name="context"      value="<%= defaultCtx %>" class="cr-ctx-hidden"
                   id="ctx_hidden_<%= row.color.replace(/[^a-zA-Z0-9]/g,'_') %>">
            <select name="family_key" class="adm-select adm-select--sm" required>
              <option value="">— select family —</option>
              <optgroup label="Cabinet Finishes">
                <% cabinetFamilies.forEach(function(f) { %>
                <option value="<%= f.key %>"><%= f.label %></option>
                <% }); %>
              </optgroup>
              <optgroup label="Metallic Finishes">
                <% metalFamilies.forEach(function(f) { %>
                <option value="<%= f.key %>"><%= f.label %></option>
                <% }); %>
              </optgroup>
            </select>
        </td>
        <td>
            <button type="submit" class="btn btn-primary btn-sm">Apply</button>
          </form>
        </td>
      </tr>
      <% }); %>
    </tbody>
  </table>
</div>

<% } /* end if unmappedColors.length */ %>

<!-- ══ Saved Color Mappings — editable ═══════════════════════════════ -->
<% if (existingMappings.length > 0) { %>
<div class="adm-section-header" style="margin-top:40px">
  <h2 class="adm-section-title">Saved Color Mappings <span style="font-size:.8rem;font-weight:400;color:#999">(<%= existingMappings.length %>)</span></h2>
  <p style="font-size:13px;color:#666;margin:0">
    Edit the BVO family for any vendor color and click Save — updates the mapping <em>and</em> re-applies to all matching products.
    Removing a mapping leaves existing products unchanged.
  </p>
</div>
<div class="adm-table-wrap" style="margin-top:12px">
  <table class="adm-table cr-edit-table">
    <thead>
      <tr>
        <th style="min-width:180px">Vendor Color</th>
        <th style="width:110px">Context</th>
        <th style="min-width:180px">BVO Family</th>
        <th>Notes</th>
        <th style="width:130px"></th>
      </tr>
    </thead>
    <tbody>
      <% existingMappings.forEach(function(m) {
           var cabinetFamilies = families.filter(function(f){ return f.type==='cabinet'; });
           var metalFamilies   = families.filter(function(f){ return f.type==='metal'; });
      %>
      <tr class="cr-edit-row">
        <td>
          <strong style="font-size:.875rem"><%= m.vendor_color %></strong>
        </td>
        <td>
          <form method="POST" action="/admin/products/color-mapping/update" class="cr-edit-form">
          <input type="hidden" name="vendor_color" value="<%= m.vendor_color %>">
          <select name="context" class="adm-select adm-select--sm">
            <option value="cabinet" <%= m.context === 'cabinet' ? 'selected' : '' %>>Cabinet</option>
            <option value="metal"   <%= m.context === 'metal'   ? 'selected' : '' %>>Metal</option>
          </select>
        </td>
        <td>
          <select name="family_key" class="adm-select adm-select--sm" required>
            <optgroup label="Cabinet Finishes">
              <% cabinetFamilies.forEach(function(f) { %>
              <option value="<%= f.key %>" <%= m.family_key === f.key ? 'selected' : '' %>><%= f.label %></option>
              <% }); %>
            </optgroup>
            <optgroup label="Metallic Finishes">
              <% metalFamilies.forEach(function(f) { %>
              <option value="<%= f.key %>" <%= m.family_key === f.key ? 'selected' : '' %>><%= f.label %></option>
              <% }); %>
            </optgroup>
          </select>
        </td>
        <td>
          <input type="text" name="notes" class="adm-input adm-input--sm"
                 value="<%= m.notes || '' %>" placeholder="optional note">
        </td>
        <td style="white-space:nowrap">
          <button type="submit" class="btn btn-primary btn-sm">Save</button>
          </form>
          <form method="POST" action="/admin/products/color-mapping/delete" style="display:inline"
                onsubmit="return confirm('Remove mapping for «<%= m.vendor_color %>»?\n\nExisting product color_family values will NOT be changed.')">
            <input type="hidden" name="vendor_color" value="<%= m.vendor_color %>">
            <button type="submit" class="btn btn-sm cr-btn-remove">Remove</button>
          </form>
        </td>
      </tr>
      <% }); %>
    </tbody>
  </table>
</div>
<% } %>

<style>
.cr-edit-table td { vertical-align: middle; padding: 7px 10px; }
.cr-edit-form { display: contents; }
.adm-input { border:1px solid #d0cdc8;border-radius:6px;padding:5px 8px;font-size:.8rem;color:#333;background:#fff;width:100%;box-sizing:border-box }
.adm-input--sm { font-size:.78rem;padding:4px 7px }
.cr-btn-remove { border:1px solid #d0cdc8;background:#fff;color:#888;font-size:.75rem;padding:4px 10px;border-radius:5px;cursor:pointer;margin-left:4px }
.cr-btn-remove:hover { border-color:#dc3545;color:#dc3545;background:#fff5f5 }
</style>

<script>
// Keep the hidden context input in sync with the context select for each row
document.querySelectorAll('.cr-ctx-select').forEach(function(sel) {
  sel.addEventListener('change', function() {
    var id = 'ctx_hidden_' + this.dataset.color.replace(/[^a-zA-Z0-9]/g, '_');
    var hidden = document.getElementById(id);
    if (hidden) hidden.value = this.value;
  });
});
</script>
