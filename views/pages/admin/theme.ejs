/* ════════════════════════════════════════════════════════════════
   IMAGE UPLOAD
   ════════════════════════════════════════════════════════════════ */
/* Find an input by name, bypassing CSS-selector bracket-escaping issues.
   `document.querySelector('[name="a[0].b"]')` fails because `[0]` is
   parsed as a CSS attribute sub-selector.  Array.find is always safe. */
function _findByName(name) {
  return Array.prototype.find.call(document.querySelectorAll('input,select,textarea'), function(el){ return el.name === name; });
}

function wireUploadBtns(root) {
  (root || document).querySelectorAll('.te4-upload-input').forEach(function (input) {
    if (input._wired) return; input._wired = true;
    input.addEventListener('change', function () {
      var file = input.files[0]; if (!file) return;
      var label = input.closest('label');
      if (label) { label.style.opacity = '.5'; label.style.pointerEvents = 'none'; }
      var fd = new FormData(); fd.append('image', file);
      fetch('/admin/upload', { method: 'POST', body: fd })
        .then(function (r) {
          if (!r.ok) throw new Error('Server returned ' + r.status);
          return r.json();
        })
        .then(function (data) {
          if (!data.ok) throw new Error(data.error || 'Upload rejected');
          var urlInput = _findByName(input.dataset.targetName);
          if (urlInput) {
            urlInput.value = data.url;
            // Support both new .te4-image-block and legacy .te4-image-field/.te4-img-row
            var wrap = urlInput.closest('.te4-image-block') || urlInput.closest('.te4-image-field') || urlInput.closest('.te4-img-row');
            if (wrap) {
              var previewWrap = wrap.querySelector('.te4-img-preview-wrap') || wrap;
              var thumb = previewWrap.querySelector('.te4-img-thumb');
              var empty = previewWrap.querySelector('.te4-img-empty');
              if (thumb) { thumb.src = data.url; }
              else if (empty) { var img2 = document.createElement('img'); img2.src = data.url; img2.className = 'te4-img-thumb'; img2.alt = ''; empty.replaceWith(img2); }
              // Update filename label
              var fname = wrap.querySelector('.te4-img-fname');
              if (fname) fname.textContent = data.url.split('/').pop();
            }
          }
          pushHistory(); markDirty(); schedulePreview();
        })
        .catch(function (e) {
          console.error('Upload failed', e);
          alert('Image upload failed: ' + e.message + '\n\nYou can paste an image URL directly into the URL field instead.');
        })
        .finally(function () {
          if (label) { label.style.opacity = ''; label.style.pointerEvents = ''; }
          input.value = '';
        });
    });
  });
}
wireUploadBtns(document);

/* ── Image remove buttons ─────────────────────────────────── */
function wireImageRemoveBtns(root) {
  (root || document).querySelectorAll('.te4-img-remove-btn').forEach(function (btn) {
    if (btn._wired) return; btn._wired = true;
    btn.addEventListener('click', function () {
      var targetName = btn.dataset.targetName;
      // Clear URL hidden field
      var urlInput = btn.closest('.te4-image-block').querySelector('.te4-img-url-hidden');
      if (urlInput) urlInput.value = '';
      // Clear preview
      var wrap = btn.closest('.te4-image-block').querySelector('.te4-img-preview-wrap');
      if (wrap) wrap.innerHTML = '<div class="te4-img-empty"><svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" opacity=".4"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg><span>No image</span></div>';
      // Clear filename label
      var fname = btn.closest('.te4-image-block').querySelector('.te4-img-fname');
      if (fname) fname.textContent = '';
      pushHistory(); markDirty(); schedulePreview();
    });
  });
}
wireImageRemoveBtns(document);

