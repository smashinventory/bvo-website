            <div class="te4-field"><label>Layout mode</label><select name="image_with_text.image_position" class="te4-select"><option value="left" <%=(iwtsec.image_position||'left')==='left'?'selected':''%>>Image left, text right</option><option value="right" <%=iwtsec.image_position==='right'?'selected':''%>>Image right, text left</option><option value="center" <%=iwtsec.image_position==='center'?'selected':''%>>Center — text over image</option></select></div>
