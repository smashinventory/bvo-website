              <div class="te4-field"><label>Columns</label><select name="featured_section.columns" class="te4-select"><option value="2" <%=(fsec.columns||'4')==='2'?'selected':''%>>2</option><option value="3" <%=fsec.columns==='3'?'selected':''%>>3</option><option value="4" <%=(fsec.columns||'4')==='4'?'selected':''%>>4 (default)</option></select></div>
