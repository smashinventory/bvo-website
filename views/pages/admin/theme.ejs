              <div class="te4-field"><label>Image width <small style="opacity:.6">(side-by-side only)</small></label><select name="image_with_text.image_width" class="te4-select"><option value="40%" <%=(iwtsec.image_width||'50%')==='40%'?'selected':''%>>40% image / 60% text</option><option value="50%" <%=(iwtsec.image_width||'50%')==='50%'?'selected':''%>>50% / 50% (equal)</option><option value="60%" <%=iwtsec.image_width==='60%'?'selected':''%>>60% image / 40% text</option></select></div>
              <%- teAlignment('image_with_text.text_align', iwtsec.text_align || 'left') %>
            </div>
            <div class="te4-section-label">Text content</div>
            <%- teField('text','image_with_text.eyebrow','Eyebrow',iwtsec.eyebrow) %>
            <div class="te4-row2">
              <%- teHeadingLevel('image_with_text.heading_level',iwtsec.heading_level||'h2') %>
