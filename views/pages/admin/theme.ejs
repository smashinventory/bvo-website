/* ════════════════════════════════════════════════════════════════
   DIRTY STATE & SAVE BUTTON
   ════════════════════════════════════════════════════════════════ */
function markDirty() {
  if (isDirty) return;
  isDirty = true;
  dirtyDot.hidden = false;
  saveBtn.textContent = 'Save';
  saveBtn.classList.add('is-dirty');
}

function markClean() {
  isDirty = false;
  dirtyDot.hidden = true;
  saveBtn.classList.remove('is-dirty');
}

form.addEventListener('submit', function () {
  // Brief delay so browser submits normally
  setTimeout(markClean, 200);
});

/* ════════════════════════════════════════════════════════════════
   UNDO / REDO
   ════════════════════════════════════════════════════════════════ */
function captureState() {
  var state = {};
  var fd = new FormData(form);
  fd.forEach(function (v, k) {
    if (state[k] !== undefined) {
      if (!Array.isArray(state[k])) state[k] = [state[k]];
      state[k].push(v);
    } else { state[k] = v; }
  });
  return state;
}

function applyState(state) {
  _supressHist = true;
  // Reset all inputs to state
  form.querySelectorAll('input:not([type="file"]), textarea, select').forEach(function (el) {
    if (!el.name) return;
    var val = state[el.name];
    if (el.type === 'checkbox') {
      // Checkboxes: state might be 'true'/'false' or array
      var arr = Array.isArray(val) ? val : [val];
      el.checked = arr.includes(el.value);
    } else if (el.type === 'color') {
      // Color swatches sync from hidden hex inputs
    } else {
      if (val !== undefined) el.value = Array.isArray(val) ? val[val.length - 1] : val;
    }
  });
  // Sync color swatches from hex inputs
  form.querySelectorAll('.te4-color-hex').forEach(function (hex) {
    var swatch = hex.closest('.te4-color-wrap')?.querySelector('.te4-color-swatch');
    if (swatch && hex.value) swatch.value = hex.value;
  });
  // Sync slider number display inputs (unnamed) from their paired range inputs
  form.querySelectorAll('.te4-slider-wrap').forEach(function (wrap) {
    var range = wrap.querySelector('input[type="range"]');
    var num   = wrap.querySelector('input[type="number"]');
    if (range && num && !num.name) num.value = range.value;
  });
  _supressHist = false;
  markDirty();
  schedulePreview();
}

function pushHistory() {
  if (_supressHist) return;
  // Truncate future
  if (histIdx < history.length - 1) history.splice(histIdx + 1);
  history.push(captureState());
  if (history.length > MAX_HIST) history.shift();
  histIdx = history.length - 1;
  updateUndoRedo();
}

function updateUndoRedo() {
  undoBtn.disabled = histIdx <= 0;
  redoBtn.disabled = histIdx >= history.length - 1;
}

undoBtn.addEventListener('click', function () {
  if (histIdx <= 0) return;
  histIdx--;
  applyState(history[histIdx]);
  updateUndoRedo();
});

redoBtn.addEventListener('click', function () {
  if (histIdx >= history.length - 1) return;
  histIdx++;
  applyState(history[histIdx]);
  updateUndoRedo();
});

// Keyboard shortcuts
document.addEventListener('keydown', function (e) {
  var ctrl = e.ctrlKey || e.metaKey;
  if (ctrl && e.key === 'z' && !e.shiftKey) { e.preventDefault(); undoBtn.click(); }
  if (ctrl && (e.key === 'y' || (e.key === 'z' && e.shiftKey))) { e.preventDefault(); redoBtn.click(); }
  if (ctrl && e.key === 's') { e.preventDefault(); form.submit(); }
});

// Capture initial state
setTimeout(function () { pushHistory(); }, 100);

/* ════════════════════════════════════════════════════════════════
   TOAST HELPER
   ════════════════════════════════════════════════════════════════ */
function showToast(msg, type) {
  toast.textContent = msg;
  toast.className   = 'te4-toast te4-toast-' + (type || 'success');
  toast.hidden = false;
  clearTimeout(toast._t);
  toast._t = setTimeout(function () { toast.hidden = true; }, 3000);
}

// Check for flash message passed from server redirect
<% if (typeof flash !== 'undefined' && flash) { %>
showToast('<%= flash.msg %>', '<%= flash.type %>');
<% } %>

})();
</script>

