        <a href="/" target="_blank" class="te4-open-link" title="Open store in new tab">
          <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          Open ↗
        </a>
      </div>
      <div class="te4-iframe-outer" id="te4IframeOuter">
        <div class="te4-iframe-wrap" id="te4IframeWrap">
          <iframe id="te4Frame" src="/?te_preview=1" title="Store preview"></iframe>
        </div>
      </div>
