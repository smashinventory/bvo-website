document.querySelectorAll('.te4-remove-row').forEach(wireRemoveBtn);

function wireRemoveBtn(btn) {
  if (!btn) return;
  btn.addEventListener('click', function () {
    var row  = btn.closest('.te4-array-row');
    var list = btn.closest('.te4-array-list');
    if (row) row.remove();
