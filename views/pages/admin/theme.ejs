<%
/* ════════════════════════════════════════════════════════════════
   THEME EDITOR — Shopify-style UI
   ════════════════════════════════════════════════════════════════ */

const HEADING_FONTS = ['Lora','Playfair Display','Cormorant Garamond','Libre Baskerville','EB Garamond','Crimson Pro','Fraunces','Bodoni Moda','DM Serif Display','Gilda Display'];
const BODY_FONTS    = ['Lato','Montserrat','Nunito Sans','Open Sans','Raleway','Jost','DM Sans','Inter','Poppins','Source Sans 3'];

const t    = ts || {};
const des  = t.design || {};
const seo  = t.seo    || {};
const desC = des.colors || {};

/* ── Section registry ─────────────────────────────────────── */
const HEADER_SECS = [
  { key:'nav',         label:'Navigation',      hasEnabled:false },
  { key:'promo_strip', label:'Promo Strip',     hasEnabled:true  },
];
const FOOTER_SECS = [
  { key:'footer',      label:'Footer',          hasEnabled:false },
  { key:'cart_drawer', label:'Cart Drawer',     hasEnabled:true  },
];
const THEME_SECS = [
  { key:'design',  label:'Typography & Colors' },
  { key:'seo',     label:'SEO & Meta' },
  { key:'global',  label:'Global Settings' },
];
const ALL_TEMPLATE_KEYS = ['scrolling_ticker','hero','brand_logos','categories_section','featured_section','image_with_text','before_after','trust_band','parallax','testimonials','newsletter'];
const TEMPLATE_META = {
  scrolling_ticker:   { label:'Announcement Bar',  desc:'Scrolling promo ticker at page top' },
  hero:               { label:'Hero Banner',        desc:'Full-width hero with CTAs' },
  brand_logos:        { label:'Brand Logos',        desc:'Scrolling brand marquee' },
  categories_section: { label:'Category Grid',      desc:'Shop-by-category cards' },
  featured_section:   { label:'Featured Products',  desc:'Handpicked product grid' },
  image_with_text:    { label:'Image with Text',    desc:'Split image + copy block' },
  before_after:       { label:'Before / After',     desc:'Drag-handle comparison slider' },
  trust_band:         { label:'Trust Band',         desc:'Three key stats / trust signals' },
  parallax:           { label:'Parallax Band',      desc:'Full-width parallax CTA section' },
  testimonials:       { label:'Testimonials',        desc:'Customer review cards' },
  newsletter:         { label:'Newsletter',          desc:'Email capture / sign-up section' },
};

const savedOrder = (t.homepage_section_order && t.homepage_section_order.length)
  ? t.homepage_section_order
  : ALL_TEMPLATE_KEYS;

// Build display-order list (saved order first, then any extras not yet in saved)
const orderedKeys = [];
savedOrder.forEach(function(k){ if(ALL_TEMPLATE_KEYS.includes(k)) orderedKeys.push(k); });
ALL_TEMPLATE_KEYS.forEach(function(k){ if(!orderedKeys.includes(k)) orderedKeys.push(k); });

function isSectionEnabled(key) {
  const sec = t[key];
  if (!sec || sec.enabled === undefined) return true;
  return sec.enabled !== false;
}

/* ── Section icon helper ─────────────────────────────────── */
function secIcon(key) {
  const icons = {
    nav:         '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>',
    promo_strip: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5M2 12l10 5 10-5"/></svg>',
    scrolling_ticker:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M5 12h14M12 5l7 7-7 7"/></svg>',
    hero:        '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>',
    brand_logos: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>',
    categories_section:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>',
    featured_section:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="2" y="2" width="9" height="9" rx="1"/><rect x="13" y="2" width="9" height="9" rx="1"/><rect x="2" y="13" width="9" height="9" rx="1"/><rect x="13" y="13" width="9" height="9" rx="1"/></svg>',
    image_with_text:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>',
    before_after:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="2" y="3" width="20" height="18" rx="2"/><line x1="12" y1="3" x2="12" y2="21"/></svg>',
    trust_band:  '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>',
    parallax:    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>',
    testimonials:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>',
    newsletter:  '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>',
    footer:      '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><line x1="3" y1="21" x2="21" y2="21"/><polyline points="9 3 3 9 3 21"/><polyline points="15 3 21 9 21 21"/><line x1="3" y1="9" x2="21" y2="9"/></svg>',
    cart_drawer: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>',
    design:      '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>',
    seo:         '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>',
    global:      '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>',
  };
  return icons[key] || icons['design'];
}

/* ── EJS helpers ─────────────────────────────────────────── */
function esc(v){ return (v===undefined||v===null)?'':String(v).replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

function teField(type,name,label,value,compact){
  var v=esc(value); var cls=compact?'te4-field compact':'te4-field';
  if(type==='textarea') return '<div class="'+cls+'"><label>'+label+'</label><textarea name="'+name+'" rows="3">'+v+'</textarea></div>';
  return '<div class="'+cls+'"><label>'+label+'</label><input type="'+type+'" name="'+name+'" value="'+v+'"></div>';
}
function teToggle(name,label,checked,compact){
  var cls=compact?'te4-toggle compact':'te4-toggle'; var chk=checked?'checked':'';
  return '<label class="'+cls+'"><input type="hidden" name="'+name+'" value="false"><input type="checkbox" name="'+name+'" value="true" '+chk+' class="te4-toggle-cb"><span class="te4-toggle-track"><span class="te4-toggle-thumb"></span></span><span class="te4-toggle-lbl">'+label+'</span></label>';
}
function teColor(name,label,value){
  var v=esc(value||'#000000');
  return '<div class="te4-color-field"><label>'+label+'</label><div class="te4-color-wrap"><input type="color" class="te4-color-swatch" value="'+v+'" data-for="'+name+'"><input type="text" name="'+name+'" value="'+v+'" class="te4-color-hex" maxlength="7"></div></div>';
}
function teImageField(name,label,value,compact){
  var v=esc(value||''); var cls=compact?'te4-image-field compact':'te4-image-field';
  return '<div class="'+cls+'"><label>'+label+'</label><div class="te4-img-row">'+(v?'<img class="te4-img-thumb" src="'+v+'" alt="">':'<div class="te4-img-empty">No image</div>')+'<div class="te4-img-controls"><input type="text" name="'+name+'" value="'+v+'" class="te4-img-url" placeholder="Paste URL or upload"><label class="te4-upload-label"><svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg> Upload<input type="file" accept="image/*" class="te4-upload-input" data-target-name="'+name+'"></label></div></div></div>';
}
/* Heading level picker (H1–H6) */
function teHeadingLevel(name,value,compact){
  var cls=compact?'te4-field compact':'te4-field';
  var v=value||'h2';
  var opts=['h1','h2','h3','h4','h5','h6'].map(function(h){
    return '<option value="'+h+'"'+(v===h?' selected':'')+'>'+h.toUpperCase()+'</option>';
  }).join('');
  return '<div class="'+cls+'"><label>Heading Level</label><select name="'+name+'" class="te4-select">'+opts+'</select></div>';
}

/* Text alignment picker (left / center / right) */
function teAlignment(name,value,compact){
  var cls=compact?'te4-field compact':'te4-field';
  var v=value||'left';
  var btns=[['left','<svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="15" y2="12"/><line x1="3" y1="18" x2="18" y2="18"/></svg>'],
             ['center','<svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="6" y1="12" x2="18" y2="12"/><line x1="4" y1="18" x2="20" y2="18"/></svg>'],
             ['right','<svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="9" y1="12" x2="21" y2="12"/><line x1="6" y1="18" x2="21" y2="18"/></svg>']].map(function(pair){
    var active=v===pair[0]?' is-active':'';
    return '<button type="button" class="te4-align-btn'+active+'" data-val="'+pair[0]+'" title="'+pair[0]+'">'+pair[1]+'</button>';
  }).join('');
  return '<div class="'+cls+'"><label>Alignment</label><div class="te4-align-group">'+btns+'<input type="hidden" name="'+name+'" value="'+esc(v)+'" class="te4-align-hidden"></div></div>';
}

/* Text size picker */
function teTextSize(name,value,label,min,max,compact){
  min=min||12; max=max||48; var v=parseInt(value)||16; var cls=compact?'te4-field compact':'te4-field';
  return '<div class="'+cls+'"><label>'+(label||'Font Size')+'</label><div class="te4-slider-wrap"><input type="range" class="te4-slider" name="'+name+'" min="'+min+'" max="'+max+'" step="1" value="'+v+'"><input type="number" class="te4-slider-num" min="'+min+'" max="'+max+'" step="1" value="'+v+'" aria-label="Font size"><span class="te4-slider-unit">px</span></div></div>';
}

/* Image upload field with preview, alt text, and SEO filename display */
function teImage(imgName,altName,imgValue,altValue,label,compact){
  var v=esc(imgValue||''); var av=esc(altValue||''); var cls=compact?'te4-image-block compact':'te4-image-block';
  var thumb=v?'<img class="te4-img-thumb" src="'+v+'" alt="">':'<div class="te4-img-empty"><svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" opacity=".4"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg><span>No image</span></div>';
  var fname=v?('<span class="te4-img-fname">'+v.split('/').pop()+'</span>'):'';
  return '<div class="'+cls+'"><div class="te4-img-block-label">'+label+'</div>'
    +'<div class="te4-img-preview-wrap">'+thumb+'</div>'
    +'<div class="te4-img-actions">'
    +'<label class="te4-upload-btn"><svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg> Upload image<input type="file" accept="image/*" class="te4-upload-input" data-target-name="'+imgName+'"></label>'
    +'<button type="button" class="te4-img-remove-btn" data-target-name="'+imgName+'">Remove</button>'
    +'</div>'
    +fname
    +'<input type="text" name="'+imgName+'" value="'+v+'" class="te4-img-url-hidden" placeholder="Or paste URL">'
    +'<div class="te4-field" style="margin-top:6px"><label>Alt text (SEO)</label><input type="text" name="'+altName+'" value="'+av+'" placeholder="Describe the image for screen readers"></div>'
    +'</div>';
}

function teArrayLinks(prefix,listId,tplId,items){
  var rows=items.map(function(l,i){ return '<div class="te4-array-row"><span class="te4-array-drag">⠿</span><div class="te4-array-fields te4-row2">'+teField('text',prefix+'['+i+'].label','Label',l.label,true)+teField('url',prefix+'['+i+'].url','URL',l.url,true)+'</div><button type="button" class="te4-remove-row" title="Remove">×</button></div>'; }).join('');
  var tpl='<div class="te4-array-row"><span class="te4-array-drag">⠿</span><div class="te4-array-fields te4-row2">'+teField('text',prefix+'[__i__].label','Label','',true)+teField('url',prefix+'[__i__].url','URL','',true)+'</div><button type="button" class="te4-remove-row" title="Remove">×</button></div>';
  return '<div class="te4-array-list" id="'+listId+'">'+rows+'</div><button type="button" class="te4-add-btn" data-target="'+listId+'" data-tpl="'+tplId+'">+ Add Link</button><template id="'+tplId+'">'+tpl+'</template>';
}
%>

<link rel="stylesheet" href="/css/admin-theme-editor.css">

<!-- ════════════════════════════════════════════════════════
     THEME EDITOR SHELL
     ════════════════════════════════════════════════════════ -->
<div class="te4-shell">

  <!-- ── TOP BAR ─────────────────────────────────────────── -->
  <div class="te4-topbar">
    <div class="te4-topbar-start">
      <a href="/admin" class="te4-back-pill" title="Back to Admin">
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
        Admin
      </a>
    </div>
    <div class="te4-topbar-center">
      <span class="te4-page-pill">
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        Home page
      </span>
      <span class="te4-status-pill">Active</span>
    </div>
    <div class="te4-topbar-end">
      <div class="te4-undo-redo">
        <button class="te4-ur-btn" id="te4UndoBtn" disabled title="Undo (Ctrl+Z)">
          <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.2"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.42"/></svg>
        </button>
        <button class="te4-ur-btn" id="te4RedoBtn" disabled title="Redo (Ctrl+Y)">
          <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.2"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-.49-3.42"/></svg>
        </button>
      </div>
      <div class="te4-device-btns">
        <button class="te4-dev-btn is-active" data-w="100%" title="Desktop">
          <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
        </button>
        <button class="te4-dev-btn" data-w="768px" title="Tablet">
          <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2"><rect x="4" y="2" width="16" height="20" rx="2"/><circle cx="12" cy="18" r="1"/></svg>
        </button>
        <button class="te4-dev-btn" data-w="390px" title="Mobile">
          <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2"><rect x="5" y="2" width="14" height="20" rx="2"/><circle cx="12" cy="18" r="1"/></svg>
        </button>
      </div>
      <span class="te4-dirty-dot" id="te4DirtyDot" hidden title="Unsaved changes"></span>
      <button class="te4-save-btn" id="te4SaveBtn" type="submit" form="te4Form">Save</button>
    </div>
  </div>

  <!-- ── BODY: form wraps sidebar + preview ──────────────── -->
  <form id="te4Form" action="/admin/theme" method="POST" class="te4-body" novalidate>

    <!-- Hidden: section order (updated by drag-to-reorder JS) -->
    <input type="hidden" name="homepage_section_order" id="te4OrderInput"
           value="<%= JSON.stringify(orderedKeys) %>">

    <!-- ════ SIDEBAR ══════════════════════════════════════ -->
    <aside class="te4-sidebar" id="te4Sidebar">

      <!-- ── STATE A: Section list ───────────────────────── -->
      <div class="te4-list-view" id="te4ListView">

        <!-- Theme Settings button -->
        <div class="te4-list-toprow">
          <button type="button" class="te4-theme-settings-btn" id="te4ThemeSettingsBtn">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
            Theme settings
            <svg class="te4-theme-settings-btn-arrow" viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
          </button>
        </div>

        <div class="te4-list-scroll">

          <!-- Header group (fixed, not reorderable) -->
          <div class="te4-sec-group">
            <div class="te4-group-label">Header</div>
            <% HEADER_SECS.forEach(function(sec){ %>
            <div class="te4-sec-row te4-sec-fixed" data-key="<%= sec.key %>" data-label="<%= sec.label %>">
              <span class="te4-sec-icon"><%- secIcon(sec.key) %></span>
              <span class="te4-sec-name"><%= sec.label %></span>
              <div class="te4-sec-actions">
                <button type="button" class="te4-sec-chevron" title="Edit">
                  <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
                </button>
              </div>
            </div>
            <% }) %>
          </div>

          <!-- Template group (draggable) -->
          <div class="te4-sec-group">
            <div class="te4-group-label">Template</div>
            <div class="te4-drag-list" id="te4DragList">
              <% orderedKeys.forEach(function(key){ var enabled=isSectionEnabled(key); var meta=TEMPLATE_META[key]||{}; %>
              <div class="te4-sec-row te4-sec-draggable<%= enabled?'':' is-hidden' %>"
                   draggable="true"
                   data-key="<%= key %>"
                   data-label="<%= meta.label||key %>">
                <span class="te4-drag-handle" title="Drag to reorder">⠿</span>
                <span class="te4-sec-icon"><%- secIcon(key) %></span>
                <span class="te4-sec-name"><%= meta.label||key %></span>
                <div class="te4-sec-actions">
                  <button type="button" class="te4-vis-btn <%= enabled?'is-visible':'is-hidden-btn' %>"
                          data-key="<%= key %>"
                          title="<%= enabled?'Hide section':'Show section' %>">
                    <% if(enabled){ %>
                    <svg class="icon-eye" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                    <% } else { %>
                    <svg class="icon-eye-off" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
                    <% } %>
                  </button>
                  <button type="button" class="te4-sec-chevron" title="Edit settings">
                    <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
                  </button>
                </div>
              </div>
              <% }) %>
            </div>
            <button type="button" class="te4-add-section-btn" id="te4AddSectionBtn">
              <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              Add section
            </button>
          </div>

          <!-- Footer group (fixed) -->
          <div class="te4-sec-group">
            <div class="te4-group-label">Footer</div>
            <% FOOTER_SECS.forEach(function(sec){ %>
            <div class="te4-sec-row te4-sec-fixed" data-key="<%= sec.key %>" data-label="<%= sec.label %>">
              <span class="te4-sec-icon"><%- secIcon(sec.key) %></span>
              <span class="te4-sec-name"><%= sec.label %></span>
              <div class="te4-sec-actions">
                <button type="button" class="te4-sec-chevron" title="Edit">
                  <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
                </button>
              </div>
            </div>
            <% }) %>
          </div>

        </div><!-- /te4-list-scroll -->
      </div><!-- /te4-list-view -->

      <!-- ── STATE B: Section settings ───────────────────── -->
      <div class="te4-settings-view" id="te4SettingsView" hidden>
        <div class="te4-settings-head">
          <button type="button" class="te4-settings-back" id="te4BackBtn">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
            <span class="te4-back-label" id="te4BackLabel">Home page</span>
          </button>
          <span class="te4-settings-title" id="te4SettingsTitle">Section</span>
        </div>
        <div class="te4-settings-body" id="te4SettingsBody">

          <!-- ═══════════════════════════════════════════════════
               ALL SECTION PANELS — only the active one visible
               ═══════════════════════════════════════════════════ -->

          <!-- ── THEME SETTINGS (accordion router) ─────────── -->
          <div class="te4-panel" id="panel-theme-settings">
            <p class="te4-panel-desc">Controls that apply across your entire storefront.</p>

            <details class="te4-accord" open>
              <summary class="te4-accord-head">
                <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                General
                <svg class="te4-accord-arrow" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="te4-accord-body">
                <% const gl2 = t.global||{}; %>
                <%- teField('text','global.site_name','Site Name',gl2.site_name) %>
                <%- teField('text','global.site_tagline','Tagline',gl2.site_tagline) %>
                <%- teField('email','global.contact_email','Contact Email',gl2.contact_email) %>
                <%- teField('text','global.contact_phone','Contact Phone',gl2.contact_phone) %>
                <%- teField('text','global.free_shipping_label','Free Shipping Label',gl2.free_shipping_label) %>
              </div>
            </details>

            <details class="te4-accord">
              <summary class="te4-accord-head">
                <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
                Colors
                <svg class="te4-accord-arrow" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="te4-accord-body">
                <div class="te4-colors-grid">
                  <%- teColor('design.colors.navy',   'Navy (text / ink)',    desC.navy   ||'#182840') %>
                  <%- teColor('design.colors.amber',  'Amber (accent)',       desC.amber  ||'#B8862A') %>
                  <%- teColor('design.colors.sage',   'Sage (buttons)',       desC.sage   ||'#5A7A5A') %>
                  <%- teColor('design.colors.whisper','Whisper (alt bg)',     desC.whisper||'#F8F6F2') %>
                  <%- teColor('design.colors.white',  'White (main bg)',      desC.white  ||'#FFFFFF') %>
                </div>
                <div class="te4-row2">
                  <%- teField('text','design.button_radius','Button Radius',des.button_radius||'6px') %>
                  <%- teField('text','design.card_radius',  'Card Radius',  des.card_radius  ||'12px') %>
                </div>
              </div>
            </details>

            <details class="te4-accord">
              <summary class="te4-accord-head">
                <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2"><polyline points="4 7 4 4 20 4 20 7"/><line x1="9" y1="20" x2="15" y2="20"/><line x1="12" y1="4" x2="12" y2="20"/></svg>
                Typography
                <svg class="te4-accord-arrow" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="te4-accord-body">
                <div class="te4-row2">
                  <div class="te4-field">
                    <label>Heading Font</label>
                    <select name="design.heading_font" class="te4-select">
                      <% HEADING_FONTS.forEach(function(f){ %><option value="<%= f %>" <%= (des.heading_font||'Lora')===f?'selected':'' %>><%= f %></option><% }) %>
                    </select>
                  </div>
                  <div class="te4-field">
                    <label>Body Font</label>
                    <select name="design.body_font" class="te4-select">
                      <% BODY_FONTS.forEach(function(f){ %><option value="<%= f %>" <%= (des.body_font||'Lato')===f?'selected':'' %>><%= f %></option><% }) %>
                    </select>
                  </div>
                </div>
                <div class="te4-row2">
                  <div class="te4-field">
                    <label>Base Font Size</label>
                    <div class="te4-slider-wrap">
                      <input type="range" name="design.base_size_px" min="14" max="20" step="1"
                             value="<%= des.base_size_px||16 %>" class="te4-slider">
                      <input type="number" class="te4-slider-num" value="<%= des.base_size_px||16 %>"
                             min="14" max="20" step="1" aria-label="Font size px">
                      <span class="te4-slider-unit">px</span>
                    </div>
                  </div>
                  <div class="te4-field">
                    <label>Heading Weight</label>
                    <select name="design.heading_weight" class="te4-select">
                      <% ['400','500','600','700'].forEach(function(w){ %><option value="<%= w %>" <%= (des.heading_weight||'600')===w?'selected':'' %>><%= w %></option><% }) %>
                    </select>
                  </div>
                </div>
              </div>
            </details>

            <details class="te4-accord">
              <summary class="te4-accord-head">
                <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                SEO & Meta
                <svg class="te4-accord-arrow" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="te4-accord-body">
                <%- teField('text','seo.home_title','Homepage Title',seo.home_title) %>
                <%- teField('textarea','seo.home_description','Meta Description',seo.home_description) %>
                <%- teImageField('seo.og_image','OG / Share Image',seo.og_image) %>
                <%- teField('text','seo.google_analytics_id','Google Analytics ID',seo.google_analytics_id) %>
              </div>
            </details>

          </div><!-- /panel-theme-settings -->

          <!-- ── PROMO STRIP ────────────────────────────────── -->
          <div class="te4-panel" id="panel-promo_strip">
            <% const ps = t.promo_strip||{}; %>
            <%- teToggle('promo_strip.enabled','Show Promo Strip',ps.enabled) %>
            <%- teField('text','promo_strip.message','Message',ps.message) %>
            <div class="te4-row2">
              <%- teField('text','promo_strip.link_text','Link Label',ps.link_text) %>
              <%- teField('url', 'promo_strip.link_url', 'Link URL',  ps.link_url) %>
            </div>
          </div>

          <!-- ── NAVIGATION ─────────────────────────────────── -->
          <div class="te4-panel" id="panel-nav">
            <% const nav=t.nav||{}; %>
            <div class="te4-section-label">Brand Name (3 lines)</div>
            <div class="te4-row3">
              <%- teField('text','nav.brand_line1','Line 1',nav.brand_line1,true) %>
              <%- teField('text','nav.brand_line2','Line 2 (amber)',nav.brand_line2,true) %>
              <%- teField('text','nav.brand_line3','Line 3',nav.brand_line3,true) %>
            </div>
            <div class="te4-array-header">
              <span class="te4-section-label">Nav Links</span>
              <button type="button" class="te4-add-btn" data-target="navLinksList" data-tpl="navLinkTpl">+ Add</button>
            </div>
            <div class="te4-array-list" id="navLinksList">
              <% (nav.links||[]).forEach(function(lnk,i){ %>
              <div class="te4-array-row">
                <span class="te4-array-drag">⠿</span>
                <div class="te4-array-fields te4-row3">
                  <%- teField('text','nav.links['+i+'].label','Label',lnk.label,true) %>
                  <%- teField('url', 'nav.links['+i+'].url',  'URL',  lnk.url,  true) %>
                  <%- teToggle('nav.links['+i+'].highlight','Highlight',lnk.highlight,true) %>
                </div>
                <button type="button" class="te4-remove-row">×</button>
              </div>
              <% }) %>
            </div>
            <template id="navLinkTpl">
              <div class="te4-array-row">
                <span class="te4-array-drag">⠿</span>
                <div class="te4-array-fields te4-row3">
                  <%- teField('text','nav.links[__i__].label','Label','',true) %>
                  <%- teField('url', 'nav.links[__i__].url',  'URL',  '',true) %>
                  <%- teToggle('nav.links[__i__].highlight','Highlight',false,true) %>
                </div>
                <button type="button" class="te4-remove-row">×</button>
              </div>
            </template>

            <!-- ── MEGA MENU — VANITIES ───────────────────────── -->
            <%
              var _vmAdmin  = (nav.vanities_mega || {});
              var _vmlAdmin = _vmAdmin.links || [];
              var _vmpAdmin = _vmAdmin.promo  || {};
            %>
            <div style="margin-top:1.75rem">
              <div class="te4-section-label">Mega Menu — Shop By Type Links</div>
              <p style="font-size:.78rem;color:var(--te4-muted,#888);margin:.25rem 0 .75rem">
                "Shop By Finish" and "Shop By Size" columns populate automatically from your product catalog — no editing needed.
              </p>
              <%- teField('text','nav.vanities_mega.section_heading','Section heading',_vmAdmin.section_heading||'Shop By Type',true) %>
              <div class="te4-array-header" style="margin-top:.75rem">
                <span style="font-size:.8rem;font-weight:600">Type Links</span>
                <button type="button" class="te4-add-btn" data-target="megaVanitiesList" data-tpl="megaVanitiesTpl">+ Add Link</button>
              </div>
              <div class="te4-array-list" id="megaVanitiesList">
                <% _vmlAdmin.forEach(function(sl,j){ %>
                <div class="te4-array-row">
                  <span class="te4-array-drag">⠿</span>
                  <div class="te4-array-fields te4-row2">
                    <%- teField('text','nav.vanities_mega.links['+j+'].label','Label', sl.label, true) %>
                    <%- teField('text','nav.vanities_mega.links['+j+'].url',  'URL / slug (relative path or ?filter=value)', sl.url, true) %>
                  </div>
                  <button type="button" class="te4-remove-row">×</button>
                </div>
                <% }) %>
              </div>
              <template id="megaVanitiesTpl">
                <div class="te4-array-row">
                  <span class="te4-array-drag">⠿</span>
                  <div class="te4-array-fields te4-row2">
                    <%- teField('text','nav.vanities_mega.links[__i__].label','Label', '', true) %>
                    <%- teField('text','nav.vanities_mega.links[__i__].url',  'URL / slug', '', true) %>
                  </div>
                  <button type="button" class="te4-remove-row">×</button>
                </div>
              </template>
            </div>

            <div style="margin-top:1.75rem">
              <div class="te4-section-label">Mega Menu — Promo Card (right column)</div>
              <div class="te4-row2" style="margin-top:.5rem">
                <%- teField('text','nav.vanities_mega.promo.eyebrow','Eyebrow text', _vmpAdmin.eyebrow||'', true) %>
                <%- teField('text','nav.vanities_mega.promo.cta',    'Button text',  _vmpAdmin.cta||'',    true) %>
              </div>
              <%- teField('text','nav.vanities_mega.promo.url',   'Card URL (slug or path)', _vmpAdmin.url||'',   true) %>
              <%- teField('text','nav.vanities_mega.promo.title', 'Title (HTML ok — use &lt;br&gt; for line break)', _vmpAdmin.title||'', true) %>
              <%- teField('textarea','nav.vanities_mega.promo.sub','Sub-text', _vmpAdmin.sub||'', true) %>
            </div>
          </div>

          <!-- ── SCROLLING TICKER ───────────────────────────── -->
          <div class="te4-panel" id="panel-scrolling_ticker">
            <% const stk=t.scrolling_ticker||{}; %>
            <%- teToggle('scrolling_ticker.enabled','Show announcement bar',stk.enabled) %>
            <%- teField('number','scrolling_ticker.speed_seconds','Scroll speed (seconds)',stk.speed_seconds||40) %>
            <div class="te4-array-header">
              <span class="te4-section-label">Messages</span>
              <button type="button" class="te4-add-btn" data-target="tickerItemsList" data-tpl="tickerItemTpl">+ Add</button>
            </div>
            <div class="te4-array-list" id="tickerItemsList">
              <% (stk.items||[]).forEach(function(item,i){ %>
              <div class="te4-array-row">
                <span class="te4-array-drag">⠿</span>
                <div class="te4-array-fields"><%- teField('text','scrolling_ticker.items['+i+'].text','Message',item,true) %></div>
                <button type="button" class="te4-remove-row">×</button>
              </div>
              <% }) %>
            </div>
            <template id="tickerItemTpl">
              <div class="te4-array-row">
                <span class="te4-array-drag">⠿</span>
                <div class="te4-array-fields"><%- teField('text','scrolling_ticker.items[__i__].text','Message','',true) %></div>
                <button type="button" class="te4-remove-row">×</button>
              </div>
            </template>
          </div>

          <!-- ── HERO ───────────────────────────────────────── -->
          <div class="te4-panel" id="panel-hero">
            <% const h=t.hero||{}; %>
            <div class="te4-section-label">Background Image</div>
            <%- teImage('hero.image_url','hero.image_alt',h.image_url,h.image_alt,'Hero Image') %>
            <div class="te4-section-label">Layout</div>
            <div class="te4-row2">
              <%- teAlignment('hero.text_align',h.text_align) %>
              <div class="te4-field"><label>Section Height</label><select name="hero.height" class="te4-select"><option value="full" <%=(h.height||'full')==='full'?'selected':''%>>Full screen</option><option value="large" <%=h.height==='large'?'selected':''%>>Large (80vh)</option><option value="medium" <%=h.height==='medium'?'selected':''%>>Medium (60vh)</option></select></div>
            </div>
            <div class="te4-section-label">Overlay</div>
            <div class="te4-row2">
              <%- teColor('hero.overlay_color','Overlay color',h.overlay_color||'#0f1f35') %>
              <div class="te4-field"><label>Overlay opacity</label><div class="te4-slider-wrap"><input type="range" class="te4-slider" name="hero.overlay_opacity" min="0" max="90" step="5" value="<%=h.overlay_opacity||55%>"><input type="number" class="te4-slider-num" min="0" max="90" step="5" value="<%=h.overlay_opacity||55%>"><span class="te4-slider-unit">%</span></div></div>
            </div>
            <div class="te4-section-label">Headline</div>
            <%- teField('text','hero.eyebrow','Eyebrow text',h.eyebrow) %>
            <div class="te4-row2">
              <%- teHeadingLevel('hero.heading_level',h.heading_level||'h1') %>
              <%- teTextSize('hero.heading_size',h.heading_size,'Heading size',28,80) %>
            </div>
            <%- teField('text','hero.heading_line1','Heading line 1',h.heading_line1) %>
            <%- teField('text','hero.heading_line2','Heading line 2 (amber accent)',h.heading_line2) %>
            <div class="te4-row2">
              <%- teTextSize('hero.subtext_size',h.subtext_size,'Subtext size',14,28) %>
            </div>
            <%- teField('textarea','hero.subtext','Subtext',h.subtext) %>
            <%- teField('text','hero.sub2_text','Brand list line',h.sub2_text) %>
            <%- teField('text','hero.badge_text','Badge text',h.badge_text) %>
            <div class="te4-section-label">Buttons</div>
            <div class="te4-row2"><%- teField('text','hero.cta1_text','Button 1 label',h.cta1_text) %><%- teField('url','hero.cta1_url','Button 1 URL',h.cta1_url) %></div>
            <div class="te4-row2"><%- teField('text','hero.cta2_text','Button 2 label',h.cta2_text) %><%- teField('url','hero.cta2_url','Button 2 URL',h.cta2_url) %></div>
          </div>

          <!-- ── BRAND LOGOS ─────────────────────────────────── -->
          <div class="te4-panel" id="panel-brand_logos">
            <% const bll=t.brand_logos||{}; %>
            <%- teToggle('brand_logos.enabled','Show brand logos',bll.enabled) %>
            <%- teField('text','brand_logos.eyebrow','Eyebrow',bll.eyebrow) %>
            <div class="te4-array-header">
              <span class="te4-section-label">Logos</span>
              <button type="button" class="te4-add-btn" data-target="brandLogosList" data-tpl="brandLogoTpl">+ Add</button>
            </div>
            <div class="te4-array-list" id="brandLogosList">
              <% (bll.logos||[]).forEach(function(logo,i){ %>
              <div class="te4-array-row">
                <span class="te4-array-drag">⠿</span>
                <div class="te4-array-fields">
                  <div class="te4-row2"><%- teField('text','brand_logos.logos['+i+'].name','Brand Name',logo.name,true) %><%- teField('url','brand_logos.logos['+i+'].url','Link URL',logo.url,true) %></div>
                  <%- teImageField('brand_logos.logos['+i+'].image_url','Logo Image',logo.image_url,true) %>
                </div>
                <button type="button" class="te4-remove-row">×</button>
              </div>
              <% }) %>
            </div>
            <template id="brandLogoTpl">
              <div class="te4-array-row">
                <span class="te4-array-drag">⠿</span>
                <div class="te4-array-fields">
                  <div class="te4-row2"><%- teField('text','brand_logos.logos[__i__].name','Brand Name','',true) %><%- teField('url','brand_logos.logos[__i__].url','Link URL','',true) %></div>
                  <%- teImageField('brand_logos.logos[__i__].image_url','Logo Image','',true) %>
                </div>
                <button type="button" class="te4-remove-row">×</button>
              </div>
            </template>
          </div>

          <!-- ── CATEGORIES ─────────────────────────────────── -->
          <div class="te4-panel" id="panel-categories_section">
            <% const catsec=t.categories_section||{}; %>
            <p class="te4-panel-desc">Category cards come from your Products → Categories database. Edit headings and layout here.</p>
            <%- teToggle('categories_section.enabled','Show section',catsec.enabled) %>
            <div class="te4-section-label">Section header</div>
            <%- teField('text','categories_section.eyebrow','Eyebrow',catsec.eyebrow) %>
            <div class="te4-row2">
              <%- teHeadingLevel('categories_section.title_level',catsec.title_level||'h2') %>
              <%- teAlignment('categories_section.text_align',catsec.text_align||'center') %>
            </div>
            <%- teField('text','categories_section.title','Title',catsec.title) %>
            <%- teField('text','categories_section.subtitle','Subtitle',catsec.subtitle) %>
            <div class="te4-section-label">Grid layout</div>
            <div class="te4-field"><label>Columns</label><select name="categories_section.columns" class="te4-select"><option value="2" <%=(catsec.columns||'4')==='2'?'selected':''%>>2 columns</option><option value="3" <%=catsec.columns==='3'?'selected':''%>>3 columns</option><option value="4" <%=(catsec.columns||'4')==='4'?'selected':''%>>4 columns (default)</option></select></div>
            <div class="te4-field"><label>Card style</label><select name="categories_section.card_style" class="te4-select"><option value="image-top" <%=(catsec.card_style||'image-top')==='image-top'?'selected':''%>>Image top</option><option value="overlay" <%=catsec.card_style==='overlay'?'selected':''%>>Text overlay</option></select></div>
          </div>

          <!-- ── FEATURED PRODUCTS ──────────────────────────── -->
          <div class="te4-panel" id="panel-featured_section">
