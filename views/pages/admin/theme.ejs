/* ════════════════════════════════════════════════════════════════
   COLOR SWATCH ↔ HEX SYNC
   ════════════════════════════════════════════════════════════════ */
document.querySelectorAll('.te4-color-swatch').forEach(function (sw) {
  var hex = sw.parentElement.querySelector('.te4-color-hex');
  sw.addEventListener('input',  function () { if (hex) hex.value = sw.value; markDirty(); schedulePreview(); });
  if (hex) hex.addEventListener('input', function () {
