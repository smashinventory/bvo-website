  </form><!-- /te4-body -->

</div><!-- /te4-shell -->

<!-- ── "Add section" modal ──────────────────────────────────── -->
<div class="te4-modal-bg" id="te4ModalBg" hidden>
  <div class="te4-modal">
    <div class="te4-modal-head">
      <h3>Add section</h3>
      <button type="button" class="te4-modal-close" id="te4ModalClose">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <p class="te4-modal-hint">Toggle visibility of existing sections using the eye icon in the list, or contact your developer to add new section types.</p>
    <div class="te4-modal-grid">
      <% orderedKeys.forEach(function(key){ var meta=TEMPLATE_META[key]||{}; var enabled=isSectionEnabled(key); %>
      <div class="te4-modal-card<%= enabled?' is-active':'' %>" data-key="<%= key %>">
        <div class="te4-modal-icon"><%- secIcon(key) %></div>
        <div class="te4-modal-card-body">
          <strong><%= meta.label||key %></strong>
          <span><%= meta.desc||'' %></span>
          <span class="te4-modal-status"><%= enabled?'Visible':'Hidden' %></span>
        </div>
        <button type="button" class="te4-modal-toggle-btn" data-key="<%= key %>">
          <%= enabled?'Hide':'Show' %>
        </button>
      </div>
      <% }) %>
    </div>
  </div>
</div>

<!-- ── Toast notification ────────────────────────────────────── -->
<div class="te4-toast" id="te4Toast" hidden></div>

<script>
(function () {
'use strict';

/* ════════════════════════════════════════════════════════════════
   STATE
   ════════════════════════════════════════════════════════════════ */
var currentView    = 'list';      // 'list' | 'settings' | 'theme'
var currentSection = null;
var isDirty        = false;

// Undo/redo history (array of serialized form states)
var history        = [];
var histIdx        = -1;
var MAX_HIST       = 50;
var _supressHist   = false;

/* ════════════════════════════════════════════════════════════════
   ELEMENT REFS
   ════════════════════════════════════════════════════════════════ */
var form       = document.getElementById('te4Form');
var sidebar    = document.getElementById('te4Sidebar');
var listView   = document.getElementById('te4ListView');
var settView   = document.getElementById('te4SettingsView');
var backBtn    = document.getElementById('te4BackBtn');
var backLabel  = document.getElementById('te4BackLabel');
var settTitle  = document.getElementById('te4SettingsTitle');
var saveBtn    = document.getElementById('te4SaveBtn');
var dirtyDot   = document.getElementById('te4DirtyDot');
var undoBtn    = document.getElementById('te4UndoBtn');
var redoBtn    = document.getElementById('te4RedoBtn');
var frame      = document.getElementById('te4Frame');
var iframeWrap = document.getElementById('te4IframeWrap');
var orderInput = document.getElementById('te4OrderInput');
var toast      = document.getElementById('te4Toast');

/* ════════════════════════════════════════════════════════════════
   SECTION ROW WIRING
   ════════════════════════════════════════════════════════════════ */
// Template section keys (can be removed/hidden)
var TEMPLATE_KEYS = ['scrolling_ticker','hero','brand_logos','categories_section',
  'featured_section','image_with_text','before_after','trust_band','parallax',
  'testimonials','newsletter'];

function openSection(key, label, backText) {
  // Fix: must set flex, not '' (which falls back to CSS display:none)
  document.querySelectorAll('.te4-panel').forEach(function (p) { p.style.display = 'none'; });
  var panel = document.getElementById('panel-' + key);
  if (panel) panel.style.display = 'flex';

  // Switch sidebar state
  listView.hidden  = true;
  settView.hidden  = false;
  settTitle.textContent = label || key;
  backLabel.textContent = backText || 'Home page';
  currentSection = key;
  currentView    = 'settings';

  // Highlight active row
  document.querySelectorAll('.te4-sec-row').forEach(function (r) {
    r.classList.toggle('is-active', r.dataset.key === key);
  });

  // Scroll settings body to top
  var body = document.getElementById('te4SettingsBody');
  if (body) body.scrollTop = 0;

  // Populate panel footer
  updatePanelFooter(key, backText);

  // Tell iframe to scroll to this section
  var isTemplate = TEMPLATE_KEYS.indexOf(key) !== -1;
  if (isTemplate && frame && frame.contentWindow) {
    frame.contentWindow.postMessage({ te4_scroll: key }, '*');
  }
}

function closeSection() {
  listView.hidden = false;
  settView.hidden = true;
  currentSection  = null;
  currentView     = 'list';
  document.querySelectorAll('.te4-sec-row').forEach(function (r) { r.classList.remove('is-active'); });
  // Clear iframe highlight
  if (frame && frame.contentWindow) {
    frame.contentWindow.postMessage({ te4_scroll: null }, '*');
  }
}

// Back button
backBtn.addEventListener('click', function () {
  // If we came from theme settings, go back to theme settings panel
  if (backBtn._returnToTheme) {
    backBtn._returnToTheme = false;
    openSection('theme-settings', 'Theme settings');
    backLabel.textContent = 'Home page';
    return;
  }
  closeSection();
});

// Click any section row (fixed or draggable) → open settings
document.querySelectorAll('.te4-sec-row').forEach(function (row) {
  row.addEventListener('click', function (e) {
    if (e.target.closest('.te4-vis-btn') || e.target.closest('.te4-drag-handle')) return;
    openSection(row.dataset.key, row.dataset.label);
    backBtn._returnToTheme = false;
  });
});

// Theme settings gear button
document.getElementById('te4ThemeSettingsBtn').addEventListener('click', function () {
  openSection('theme-settings', 'Theme settings');
  backLabel.textContent = 'Home page';
  backBtn._returnToTheme = false;
});

/* ── Panel footer (Theme Settings link + Custom CSS + Remove) ── */
var _panelFooter = document.getElementById('te4PanelFooter');

function updatePanelFooter(key, backText) {
  if (!_panelFooter) return;
  _panelFooter.innerHTML = '';

  var isTheme    = (key === 'theme-settings' || key === 'design' || key === 'seo' || key === 'global');
  var isTemplate = TEMPLATE_KEYS.indexOf(key) !== -1;

  // Custom CSS accordion (for template sections)
  if (isTemplate) {
    var cssAccord = document.createElement('details');
    cssAccord.className = 'te4-accord';
    var cssSummary = document.createElement('summary');
    cssSummary.className = 'te4-accord-head';
    cssSummary.textContent = 'Custom CSS';
    var cssBody = document.createElement('div');
    cssBody.className = 'te4-accord-body';
    var cssHint = document.createElement('p');
    cssHint.className = 'te4-css-hint';
    cssHint.textContent = 'Add custom CSS for this section only.';
    var cssTA = document.createElement('textarea');
    cssTA.name = key + '.custom_css';
    cssTA.className = 'te4-css-textarea';
    cssTA.placeholder = '.selector { property: value; }';
    // Restore existing value from form if it was set
    var existing = document.querySelector('input[name="' + key + '.custom_css_hidden"]');
    if (existing) cssTA.value = existing.value;
    cssTA.addEventListener('input', function () { markDirty(); schedulePreview(); });
    cssBody.appendChild(cssHint);
    cssBody.appendChild(cssTA);
    cssAccord.appendChild(cssSummary);
