  }
}

/* ════════════════════════════════════════════════════════════════
   SECTION VISIBILITY TOGGLE (eye icon)
   ════════════════════════════════════════════════════════════════ */
document.querySelectorAll('.te4-vis-btn').forEach(wireVisBtn);

function wireVisBtn(btn) {
  btn.addEventListener('click', function (e) {
    e.stopPropagation();
    var key     = btn.dataset.key;
    var row     = btn.closest('.te4-sec-row');
    var enabled = btn.classList.contains('is-visible');

    // Toggle
    enabled = !enabled;
    btn.classList.toggle('is-visible',    enabled);
    btn.classList.toggle('is-hidden-btn', !enabled);
    btn.title = enabled ? 'Hide section' : 'Show section';
    // Swap icon
    btn.innerHTML = enabled
      ? '<svg class="icon-eye" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>'
      : '<svg class="icon-eye-off" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>';
    row.classList.toggle('is-hidden', !enabled);

    // Update the corresponding form toggle
    var cbName = key + '.enabled';
    var hiddenInput = form.querySelector('input[type="hidden"][name="' + cbName + '"]');
    var checkInput  = form.querySelector('input[type="checkbox"][name="' + cbName + '"]');
    if (hiddenInput) hiddenInput.value = String(!enabled); // hidden = "false" when enabled
    if (checkInput)  checkInput.checked = enabled;

    // Sync modal card status
    var modalCard = document.querySelector('.te4-modal-card[data-key="' + key + '"]');
    if (modalCard) {
      modalCard.classList.toggle('is-active', enabled);
      var status = modalCard.querySelector('.te4-modal-status');
      if (status) status.textContent = enabled ? 'Visible' : 'Hidden';
      var toggleBtn = modalCard.querySelector('.te4-modal-toggle-btn');
      if (toggleBtn) toggleBtn.textContent = enabled ? 'Hide' : 'Show';
    }

    pushHistory(); markDirty(); schedulePreview();
  });
}

/* ════════════════════════════════════════════════════════════════
   DRAG-TO-REORDER (template sections)
   ════════════════════════════════════════════════════════════════ */
var dragList     = document.getElementById('te4DragList');
var dragging     = null;
var dropTarget   = null;

dragList.addEventListener('dragstart', function (e) {
  dragging = e.target.closest('.te4-sec-draggable');
  if (!dragging) return;
  dragging.classList.add('is-dragging');
  e.dataTransfer.effectAllowed = 'move';
  e.dataTransfer.setData('text/plain', dragging.dataset.key);
});

dragList.addEventListener('dragend', function () {
  if (dragging) dragging.classList.remove('is-dragging');
  document.querySelectorAll('.te4-sec-draggable').forEach(function (r) {
    r.classList.remove('drag-over-above', 'drag-over-below');
  });
  dragging = null; dropTarget = null;
  saveOrder();
});

dragList.addEventListener('dragover', function (e) {
  e.preventDefault();
  var target = e.target.closest('.te4-sec-draggable');
  if (!target || target === dragging) return;
  document.querySelectorAll('.te4-sec-draggable').forEach(function (r) {
    r.classList.remove('drag-over-above', 'drag-over-below');
  });
  var rect   = target.getBoundingClientRect();
  var midY   = rect.top + rect.height / 2;
  var above  = e.clientY < midY;
  target.classList.add(above ? 'drag-over-above' : 'drag-over-below');
  dropTarget = { el: target, above: above };
});

dragList.addEventListener('dragleave', function (e) {
  if (!dragList.contains(e.relatedTarget)) {
    document.querySelectorAll('.te4-sec-draggable').forEach(function (r) {
      r.classList.remove('drag-over-above', 'drag-over-below');
    });
  }
});

dragList.addEventListener('drop', function (e) {
  e.preventDefault();
  if (!dragging || !dropTarget) return;
  var { el, above } = dropTarget;
  if (above) dragList.insertBefore(dragging, el);
  else el.after(dragging);
  document.querySelectorAll('.te4-sec-draggable').forEach(function (r) {
    r.classList.remove('drag-over-above', 'drag-over-below');
  });
  saveOrder(); pushHistory(); markDirty();
});

function saveOrder() {
  var order = [];
  dragList.querySelectorAll('.te4-sec-draggable').forEach(function (r) { order.push(r.dataset.key); });
  orderInput.value = JSON.stringify(order);
  // Async persist order
  fetch('/admin/theme/reorder', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ order: order })
  }).catch(function () {});
  schedulePreview();
}

