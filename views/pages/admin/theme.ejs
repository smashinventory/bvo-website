/* ════════════════════════════════════════════════════════════════
   SLIDERS — bidirectional range ↔ number sync
   ════════════════════════════════════════════════════════════════ */

// Generic bidirectional: range + paired <input type=number> in same .te4-slider-wrap
document.querySelectorAll('.te4-slider-wrap').forEach(function (wrap) {
  var range = wrap.querySelector('input[type="range"]');
  var num   = wrap.querySelector('input[type="number"]');
  if (!range || !num) return;
  range.addEventListener('input', function () {
    num.value = range.value;
    markDirty(); schedulePreview();
  });
  num.addEventListener('input', function () {
    var v = parseFloat(num.value);
    var mn = parseFloat(range.min), mx = parseFloat(range.max);
    if (!isNaN(v) && v >= mn && v <= mx) {
      range.value = v;
      markDirty(); schedulePreview();
    }
  });
  num.addEventListener('blur', function () {
    // clamp on blur
    var v = parseFloat(num.value);
    var mn = parseFloat(range.min), mx = parseFloat(range.max);
    if (isNaN(v)) { num.value = range.value; return; }
    v = Math.min(mx, Math.max(mn, v));
    num.value = v;
    range.value = v;
  });
});

/* ════════════════════════════════════════════════════════════════
   LIVE PREVIEW
   ════════════════════════════════════════════════════════════════ */
var previewTimer;
var lastReload = 0;

function schedulePreview() {
  clearTimeout(previewTimer);
  previewTimer = setTimeout(sendPreview, 650);
}

function sendPreview() {
  // Must send as application/x-www-form-urlencoded so Express can parse req.body.
  // new FormData(form) sends multipart which Express urlencoded middleware ignores,
  // causing req.body={} and wiping all array fields (nav links, footer, etc.).
  var params = new URLSearchParams(new FormData(form)).toString();
  fetch('/admin/theme/preview', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/x-www-form-urlencoded',
      'X-Requested-With': 'XMLHttpRequest'
    },
    body: params
  })
    .then(function (r) { return r.json(); })
    .then(function (d) {
      if (d.ok && frame) {
        lastReload = Date.now();
        frame.src = '/?te_preview=1&_ts=' + lastReload;
      }
    }).catch(function () {});
}

// Trigger preview on any form change
form.addEventListener('input',  function () { markDirty(); schedulePreview(); });
form.addEventListener('change', function () { markDirty(); schedulePreview(); });

/* ════════════════════════════════════════════════════════════════
   CLICK-TO-EDIT — receive te4_open from preview iframe
   ════════════════════════════════════════════════════════════════ */
window.addEventListener('message', function (e) {
  var d = e.data;
  if (!d || typeof d !== 'object') return;
  if (d.te4_open) {
    var key   = d.te4_open;
    var label = d.te4_label || key;
    // Map key → TEMPLATE_META label if available
    var meta  = { scrolling_ticker:'Announcement Bar', hero:'Hero Banner', brand_logos:'Brand Logos',
                  categories_section:'Category Grid', featured_section:'Featured Products',
                  image_with_text:'Image with Text', before_after:'Before / After',
                  trust_band:'Trust Band', parallax:'Parallax Band',
                  testimonials:'Testimonials', newsletter:'Newsletter' };
    openSection(key, meta[key] || label, 'Home page');
  }
});

