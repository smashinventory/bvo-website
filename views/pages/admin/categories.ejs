<%
/**
 * Admin — Categories list
 * Locals: categories [{id, slug, name, description, image_url, sort_order, is_active, display_mode, product_count}]
 *         flash {type, msg} | null
 */
%>

<% if (locals.flash) { %>
<div class="adm-flash adm-flash--<%= flash.type %>"><%- flash.msg %></div>
<% } %>

<!-- Header bar -->
<div class="cat-list-header">
  <div>
    <h2 class="cat-list-title">Categories</h2>
    <p class="cat-list-sub"><%= categories.length %> categor<%= categories.length === 1 ? 'y' : 'ies' %></p>
  </div>
  <a href="/admin/categories/new" class="adm-btn adm-btn--primary">+ Add Category</a>
</div>

<!-- List -->
<% if (categories.length === 0) { %>
<div class="adm-empty">
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="48" height="48">
    <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
    <rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>
  </svg>
  <p>No categories yet.</p>
  <a href="/admin/categories/new" class="adm-btn adm-btn--primary" style="margin-top:12px">Add your first category</a>
</div>
<% } else { %>
<div class="cat-list-wrap">
  <% categories.forEach(function(cat) { %>
  <div class="cat-list-row">

    <!-- Thumbnail -->
    <div class="cat-list-thumb">
      <% if (cat.image_url) { %>
        <img src="<%= cat.image_url %>" alt="<%= cat.name %>">
      <% } else { %>
        <div class="cat-list-thumb-empty">
          <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="#ccc" stroke-width="1.5">
            <rect x="3" y="3" width="18" height="18" rx="2"/>
            <circle cx="8.5" cy="8.5" r="1.5"/>
            <polyline points="21 15 16 10 5 21"/>
          </svg>
        </div>
      <% } %>
    </div>

    <!-- Info -->
    <div class="cat-list-info">
      <a href="/admin/categories/<%= cat.id %>/edit" class="cat-list-name"><%= cat.name %></a>
      <span class="cat-list-slug">/collections/<%= cat.slug %></span>
    </div>

    <!-- Mode badge -->
    <div class="cat-list-mode">
      <span class="cat-badge cat-badge--<%= cat.display_mode === 'model-group' ? 'mg' : 'prod' %>">
        <%= cat.display_mode === 'model-group' ? 'Model Group' : 'Product' %>
      </span>
    </div>

    <!-- Product count -->
    <div class="cat-list-count">
      <span><%= cat.product_count %> product<%= cat.product_count !== 1 ? 's' : '' %></span>
    </div>

    <!-- Active status -->
    <div class="cat-list-status">
      <span class="cat-status cat-status--<%= cat.is_active ? 'active' : 'inactive' %>">
        <%= cat.is_active ? 'Active' : 'Draft' %>
      </span>
    </div>

    <!-- Actions -->
    <div class="cat-list-actions">
      <a href="/admin/categories/<%= cat.id %>/edit" class="adm-btn">Edit</a>
      <a href="/collections/<%= cat.slug %>" target="_blank" class="adm-btn" title="View on site">
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
      </a>
      <form method="POST" action="/admin/categories/<%= cat.id %>/delete" style="display:inline"
            onsubmit="return confirm('Delete «<%= cat.name %>»? This cannot be undone.')">
        <button class="adm-btn adm-btn--danger" type="submit">Delete</button>
      </form>
    </div>

  </div>
  <% }); %>
</div>
<% } %>

<style>
/* ── Flash ── */
.adm-flash { padding:10px 16px;border-radius:8px;margin-bottom:20px;font-size:.875rem }
.adm-flash--success { background:#f0faf2;border:1px solid #7A9E7E;color:#2d6a38 }
.adm-flash--error   { background:#fff5f5;border:1px solid #c00;color:#900 }

/* ── Header ── */
.cat-list-header { display:flex;align-items:center;justify-content:space-between;margin-bottom:24px }
.cat-list-title  { margin:0;font-size:1.25rem;font-weight:700;color:#182840 }
.cat-list-sub    { margin:4px 0 0;font-size:.8rem;color:#888 }

/* ── List ── */
.cat-list-wrap { border:1px solid #e5e0d8;border-radius:10px;overflow:hidden }
.cat-list-row  {
  display:grid;
  grid-template-columns: 56px 1fr 120px 100px 80px auto;
  align-items:center;
  gap:16px;
  padding:14px 20px;
  border-bottom:1px solid #f0ede8;
  background:#fff;
  transition:background .12s;
}
.cat-list-row:last-child { border-bottom:none }
.cat-list-row:hover      { background:#faf9f6 }

/* Thumbnail */
.cat-list-thumb     { width:56px;height:48px;border-radius:6px;overflow:hidden;border:1px solid #e5e0d8;flex-shrink:0 }
.cat-list-thumb img { width:100%;height:100%;object-fit:cover;display:block }
.cat-list-thumb-empty { width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:#f8f6f2 }

/* Info */
.cat-list-info  { min-width:0 }
.cat-list-name  { font-weight:700;font-size:.9rem;color:#182840;text-decoration:none;display:block;white-space:nowrap;overflow:hidden;text-overflow:ellipsis }
.cat-list-name:hover { color:#B8963A }
.cat-list-slug  { font-size:.72rem;color:#aaa;display:block;white-space:nowrap;overflow:hidden;text-overflow:ellipsis }

/* Mode badge */
.cat-badge         { font-size:.68rem;font-weight:700;padding:2px 8px;border-radius:12px;letter-spacing:.04em;white-space:nowrap }
.cat-badge--prod   { background:#e8f4ff;color:#1a6eb5 }
.cat-badge--mg     { background:#f3edff;color:#6b3fa0 }

/* Count */
.cat-list-count { font-size:.8rem;color:#888;white-space:nowrap }

/* Status */
.cat-status          { font-size:.72rem;font-weight:700;padding:3px 10px;border-radius:12px;white-space:nowrap }
.cat-status--active  { background:#e6f9ee;color:#1e7a3c }
.cat-status--inactive{ background:#f5f5f5;color:#999;border:1px solid #e0e0e0 }

/* Actions */
.cat-list-actions { display:flex;align-items:center;gap:6px }

/* Shared buttons */
.adm-btn { display:inline-flex;align-items:center;gap:5px;padding:6px 14px;border-radius:6px;border:1px solid #d0cdc8;background:#fff;font-size:.8rem;font-weight:600;cursor:pointer;color:#333;text-decoration:none;white-space:nowrap }
.adm-btn:hover      { border-color:#B8963A;color:#B8963A }
.adm-btn--primary   { background:#B8963A;border-color:#B8963A;color:#fff }
.adm-btn--primary:hover { background:#a07c28;border-color:#a07c28;color:#fff }
.adm-btn--danger    { border-color:#dc3545;color:#dc3545 }
.adm-btn--danger:hover  { background:#fff5f5 }

/* Empty state */
.adm-empty { text-align:center;padding:60px 24px;color:#aaa }
.adm-empty svg { margin-bottom:16px;opacity:.35 }
.adm-empty p   { font-size:.95rem;margin:0 }

@media (max-width:768px) {
  .cat-list-row { grid-template-columns:48px 1fr auto;gap:10px }
  .cat-list-mode,.cat-list-count,.cat-list-status { display:none }
}
</style>
