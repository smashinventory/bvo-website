<div class="adm-form-page">
  <div class="adm-form-header">
    <a href="/admin/products" class="adm-back-link">← Products</a>
    <h1 class="adm-form-title"><%= isNew ? 'Add New Product' : 'Edit Product' %></h1>
    <% if (!isNew && product) { %>
    <a href="/products/<%= product.slug %>" target="_blank" class="btn btn-outline" style="margin-left:auto">View in Store ↗</a>
    <% } %>
  </div>

  <% if (locals.flash) { %>
  <div class="adm-flash adm-flash--<%= flash.type %>"><%= flash.msg %></div>
  <% } %>

  <form action="<%= isNew ? '/admin/products' : '/admin/products/' + product.id %>"
        method="POST" class="adm-form" id="productForm">
    <div class="adm-form-grid">

      <!-- ══ LEFT COLUMN ══════════════════════════════════════════ -->
      <div class="adm-form-main">

        <!-- ── Basic Information ─────────────────────────────── -->
        <div class="adm-card">
          <h2 class="adm-card-title">Basic Information</h2>

          <div class="adm-form-group">
            <label for="name">Product Name <span class="adm-required">*</span></label>
            <input type="text" id="name" name="name" required
              value="<%= product?.name || '' %>"
              placeholder="e.g. James Martin Brookfield 60&quot; Single Vanity">
          </div>

          <div class="adm-form-row">
            <div class="adm-form-group">
              <label for="slug">URL Slug</label>
              <input type="text" id="slug" name="slug"
                value="<%= product?.slug || '' %>" placeholder="auto-generated from name">
              <span class="adm-form-hint">Leave blank to auto-generate</span>
            </div>
            <div class="adm-form-group">
              <label for="sku">SKU <span class="adm-required">*</span></label>
              <input type="text" id="sku" name="sku"
                value="<%= product?.sku || '' %>" placeholder="e.g. JM-BROOK-60-WW">
            </div>
          </div>

          <div class="adm-form-row">
            <div class="adm-form-group">
              <label for="vendor_sku">Vendor SKU / Model #</label>
              <input type="text" id="vendor_sku" name="vendor_sku"
                value="<%= product?.vendor_sku || '' %>" placeholder="Manufacturer's model number">
            </div>
            <div class="adm-form-group">
              <label for="upc">UPC / Barcode</label>
              <input type="text" id="upc" name="upc"
                value="<%= product?.upc || '' %>" placeholder="12-digit UPC">
            </div>
          </div>

          <div class="adm-form-row">
            <div class="adm-form-group">
              <label for="brand">Brand</label>
              <input type="text" id="brand" name="brand"
                value="<%= product?.brand || '' %>" placeholder="e.g. James Martin">
            </div>
            <div class="adm-form-group">
              <label for="category_id">Category</label>
              <select id="category_id" name="category_id">
                <option value="">— Select —</option>
                <% categories.forEach(c => { %>
                <option value="<%= c.id %>" <%= (product?.category_id == c.id) ? 'selected' : '' %>><%= c.name %></option>
                <% }) %>
              </select>
            </div>
          </div>

          <div class="adm-form-row">
            <div class="adm-form-group">
              <label for="product_type">Product Type</label>
              <input type="text" id="product_type" name="product_type"
                value="<%= product?.product_type || '' %>"
                placeholder="e.g. Single Sink Vanity"
                list="product-type-list">
              <datalist id="product-type-list">
                <option value="Single Sink Vanity">
                <option value="Double Sink Vanity">
                <option value="Freestanding Vanity">
                <option value="Wall-Mount Vanity">
                <option value="Corner Vanity">
                <option value="Vessel Sink Vanity">
                <option value="Framed Mirror">
                <option value="Frameless Mirror">
                <option value="LED Mirror">
                <option value="Medicine Cabinet">
                <option value="Single Handle Faucet">
                <option value="Widespread Faucet">
                <option value="Centerset Faucet">
              </datalist>
            </div>
            <div class="adm-form-group">
              <label for="component_role">Component Role</label>
              <select id="component_role" name="component_role">
                <option value="" <%= !product?.component_role ? 'selected' : '' %>>— Standalone product —</option>
                <option value="base"    <%= product?.component_role === 'base'    ? 'selected' : '' %>>Base / Cabinet</option>
                <option value="top"     <%= product?.component_role === 'top'     ? 'selected' : '' %>>Countertop / Top</option>
                <option value="mirror"  <%= product?.component_role === 'mirror'  ? 'selected' : '' %>>Mirror</option>
                <option value="faucet"  <%= product?.component_role === 'faucet'  ? 'selected' : '' %>>Faucet</option>
                <option value="sink"    <%= product?.component_role === 'sink'    ? 'selected' : '' %>>Sink</option>
                <option value="hardware"<%= product?.component_role === 'hardware'? 'selected' : '' %>>Hardware / Pulls</option>
                <option value="other"   <%= product?.component_role === 'other'   ? 'selected' : '' %>>Other</option>
              </select>
              <span class="adm-form-hint">For items sold as part of a set</span>
            </div>
          </div>

          <div class="adm-form-row">
            <div class="adm-form-group">
              <label for="vendor_group_id">Vendor Group ID</label>
              <input type="text" id="vendor_group_id" name="vendor_group_id"
                value="<%= product?.vendor_group_id || '' %>"
                placeholder="Groups items that belong to the same set">
            </div>
            <div class="adm-form-group">
              <label for="country_origin">Country of Origin</label>
              <input type="text" id="country_origin" name="country_origin"
                value="<%= product?.country_origin || '' %>" placeholder="e.g. Vietnam, USA">
            </div>
          </div>
        </div>

        <!-- ── Descriptions ──────────────────────────────────── -->
        <div class="adm-card">
          <h2 class="adm-card-title">Descriptions</h2>
          <div class="adm-form-group">
            <label for="short_desc">Short Description</label>
            <textarea id="short_desc" name="short_desc" rows="3"
              placeholder="1–2 sentences shown beneath the title on the product page."><%= product?.short_desc || '' %></textarea>
          </div>
          <div class="adm-form-group">
            <label for="long_desc">Full Description</label>
            <textarea id="long_desc" name="long_desc" rows="8"
              placeholder="Detailed product description — HTML is supported."><%= product?.long_desc || '' %></textarea>
            <span class="adm-form-hint">Rendered in the "Product Description" section. HTML allowed.</span>
          </div>
          <div class="adm-form-group">
            <label for="warranty">Warranty</label>
            <input type="text" id="warranty" name="warranty"
              value="<%= product?.warranty || '' %>"
              placeholder="e.g. Limited Lifetime Warranty on cabinet, 1 Year on hardware">
          </div>
        </div>

        <!-- ── Pricing ───────────────────────────────────────── -->
        <div class="adm-card">
          <h2 class="adm-card-title">Pricing</h2>
          <div class="adm-form-row adm-form-row--3">
            <div class="adm-form-group">
              <label for="price">Retail Price <span class="adm-required">*</span></label>
              <div class="adm-input-prefix">
                <span>$</span>
                <input type="number" id="price" name="price" required min="0" step="0.01"
                  value="<%= product?.price || '' %>" placeholder="0.00">
              </div>
            </div>
            <div class="adm-form-group">
              <label for="compare_price">Compare-At Price</label>
              <div class="adm-input-prefix">
                <span>$</span>
                <input type="number" id="compare_price" name="compare_price" min="0" step="0.01"
                  value="<%= product?.compare_price || '' %>" placeholder="0.00">
              </div>
              <span class="adm-form-hint">Shows strikethrough "was" price + savings badge</span>
            </div>
            <div class="adm-form-group">
              <label for="cost">Cost / Wholesale</label>
              <div class="adm-input-prefix">
                <span>$</span>
                <input type="number" id="cost" name="cost" min="0" step="0.01"
                  value="<%= product?.cost || '' %>" placeholder="0.00">
              </div>
              <span class="adm-form-hint">Internal only — not shown to customers</span>
            </div>
          </div>
        </div>

        <!-- ── Dimensions & Shipping ─────────────────────────── -->
        <div class="adm-card">
          <h2 class="adm-card-title">Dimensions &amp; Shipping</h2>
          <p class="adm-card-subtitle">Product dimensions (assembled)</p>
          <div class="adm-form-row adm-form-row--4">
            <div class="adm-form-group">
              <label for="width_in">Width (in)</label>
              <input type="number" id="width_in" name="width_in" min="0" step="0.25"
                value="<%= product?.width_in || '' %>" placeholder="60">
            </div>
            <div class="adm-form-group">
              <label for="depth_in">Depth (in)</label>
              <input type="number" id="depth_in" name="depth_in" min="0" step="0.25"
                value="<%= product?.depth_in || '' %>" placeholder="22">
            </div>
            <div class="adm-form-group">
              <label for="height_in">Height (in)</label>
              <input type="number" id="height_in" name="height_in" min="0" step="0.25"
                value="<%= product?.height_in || '' %>" placeholder="34">
            </div>
            <div class="adm-form-group">
              <label for="weight_lbs">Weight (lbs)</label>
              <input type="number" id="weight_lbs" name="weight_lbs" min="0" step="0.1"
                value="<%= product?.weight_lbs || '' %>" placeholder="250">
            </div>
          </div>

          <p class="adm-card-subtitle" style="margin-top:16px">Freight &amp; Logistics</p>
          <div class="adm-form-row adm-form-row--4">
            <div class="adm-form-group">
              <label for="total_ship_weight_lbs">Ship Weight (lbs)</label>
              <input type="number" id="total_ship_weight_lbs" name="total_ship_weight_lbs" min="0" step="0.1"
                value="<%= product?.total_ship_weight_lbs || '' %>" placeholder="280">
              <span class="adm-form-hint">Including packaging</span>
            </div>
            <div class="adm-form-group">
              <label for="freight_class">Freight Class</label>
              <select id="freight_class" name="freight_class">
                <option value="">— Select —</option>
                <% ['50','55','60','65','70','77.5','85','92.5','100','110','125','150','175','200','250','300','400','500'].forEach(fc => { %>
                <option value="<%= fc %>" <%= product?.freight_class === fc ? 'selected' : '' %>><%= fc %></option>
                <% }) %>
              </select>
            </div>
            <div class="adm-form-group">
              <label for="harmonized_code">Harmonized Code</label>
              <input type="text" id="harmonized_code" name="harmonized_code"
                value="<%= product?.harmonized_code || '' %>" placeholder="e.g. 9403.40.9080">
            </div>
            <div class="adm-form-group">
              <label for="lead_time_days">Lead Time (days)</label>
              <input type="number" id="lead_time_days" name="lead_time_days" min="0" step="1"
                value="<%= product?.lead_time_days || '' %>" placeholder="14">
            </div>
          </div>
          <div style="margin-top:8px">
            <label class="adm-toggle-label">
              <input type="checkbox" name="ships_ltl" value="1"
                <%= product?.ships_ltl ? 'checked' : '' %>>
              Ships via LTL freight (oversize — requires freight shipping)
            </label>
          </div>
        </div>

        <!-- ── Specifications (EAV attributes) ───────────────── -->
        <div class="adm-card">
          <h2 class="adm-card-title">Specifications</h2>
          <p class="adm-form-hint" style="margin-bottom:14px">
            These power the collection filters and appear in the Specs table on the product page.
            Use <strong>Numeric value</strong> for sizes, counts, and measurements.
            Use <strong>Text value</strong> for colors, materials, and named options.
          </p>

          <datalist id="spec-keys">
            <option value="product_type"><option value="size_in">
            <option value="style"><option value="mount_type">
            <option value="cabinet_finish">
            <option value="hardware_finish"><option value="hardware_color">
            <option value="sink_count"><option value="sink_type"><option value="sink_included">
            <option value="countertop_material"><option value="countertop_included">
            <option value="door_style"><option value="drawer_count">
            <option value="mirror_included"><option value="faucet_holes">
            <option value="faucet_spread_in"><option value="finish">
            <option value="shape"><option value="has_led"><option value="has_defogger">
            <option value="material"><option value="width_in">
            <option value="depth_in"><option value="height_in">
            <option value="handle_type"><option value="spout_type">
            <option value="flow_rate_gpm"><option value="faucet_config">
            <option value="fixture_type"><option value="bulb_type">
            <option value="num_lights">
            <!-- JM-specific feature flags -->
            <option value="soft_close_hinges"><option value="soft_close_slides">
            <option value="backsplash_included"><option value="wireless_charging">
            <option value="freepower_compatible"><option value="ada_compliant">
            <option value="adjustable_shelves"><option value="assembly_required">
            <option value="has_electrical"><option value="has_makeup_counter">
            <!-- JM-specific descriptive specs -->
            <option value="bowl_shape"><option value="distressed_finish">
            <option value="countertop_finish"><option value="countertop_thickness">
            <option value="primary_material"><option value="construction_material">
            <option value="sink_material"><option value="sink_installation">
            <option value="sink_overflow"><option value="drain_included">
            <option value="sink_width_in"><option value="sink_depth_in">
            <option value="sink_basin_depth_in"><option value="backsplash_material">
            <option value="drawer_organizer">
            <option value="num_doors"><option value="num_shelves">
            <option value="num_drawers"><option value="tip_out_drawers">
            <option value="weight_lbs">
          </datalist>

          <div id="specs-list">
            <%
              var _specs = (typeof productAttrs !== 'undefined' && productAttrs.length) ? productAttrs : [];
            %>
            <% _specs.forEach(function(s, i) { %>
            <div class="spec-row-edit">
              <input type="text"   name="spec[<%= i %>][key]"  value="<%= s.attr_key %>"
                placeholder="attr_key" list="spec-keys" class="spec-key-input">
              <input type="text"   name="spec[<%= i %>][text]" value="<%= s.value_text || '' %>"
                placeholder="Text value">
              <input type="number" name="spec[<%= i %>][num]"  value="<%= s.value_num != null ? s.value_num : '' %>"
                placeholder="Numeric value" step="any">
              <button type="button" class="spec-remove-btn" title="Remove">✕</button>
            </div>
            <% }) %>
          </div>
          <button type="button" id="add-spec-btn" class="btn btn-outline"
            style="margin-top:10px;font-size:.8rem;padding:6px 14px">+ Add Spec Row</button>
        </div>

        <!-- ── Colors ────────────────────────────────────────── -->
        <div class="adm-card">
          <h2 class="adm-card-title">Colors</h2>
          <p class="adm-form-hint" style="margin-bottom:14px">
            <strong>Primary Color</strong> is the normalized filter value (Black, White, Gray…) that
            powers the color filter on collection pages.
            <strong>Secondary Color</strong> is the vendor's specific name (Dark Onyx, Antique Coffee…)
            shown on the product page and submitted to Google Merchant Center.
          </p>

          <div class="adm-form-row">
            <div class="adm-form-group">
              <label for="color_primary">Primary Color <span class="adm-form-hint" style="font-weight:400">(filter)</span></label>
              <input type="text" id="color_primary" name="color_primary"
                value="<%= product?.color_primary || '' %>"
                placeholder="e.g. Black"
                list="color-primary-list">
              <datalist id="color-primary-list">
                <option value="Black">
                <option value="White">
                <option value="Gray">
                <option value="Brown">
                <option value="Blue">
                <option value="Green">
                <option value="Navy">
                <option value="Gold">
                <option value="Silver">
                <option value="Natural Wood">
                <option value="Two-Tone">
                <option value="Red">
                <option value="Off-White">
              </datalist>
              <span class="adm-form-hint">Broad color for collection filter — must match your filter taxonomy exactly</span>
            </div>
            <div class="adm-form-group">
              <label for="color_secondary">Secondary Color <span class="adm-form-hint" style="font-weight:400">(vendor name)</span></label>
              <input type="text" id="color_secondary" name="color_secondary"
                value="<%= product?.color_secondary || '' %>"
                placeholder="e.g. Dark Onyx">
              <span class="adm-form-hint">Vendor's specific color name — shown on product page &amp; sent to Google</span>
            </div>
          </div>
        </div>

        <!-- ── Google Merchant Center ────────────────────────── -->
        <div class="adm-card">
          <h2 class="adm-card-title">Google Merchant Center</h2>
          <p class="adm-form-hint" style="margin-bottom:14px">
            These fields power the GMC product feed. Required fields are <strong>google_condition</strong> and <strong>google_product_category</strong>.
          </p>

          <div class="adm-form-row">
            <div class="adm-form-group">
              <label for="mpn">MPN (Manufacturer Part #)</label>
              <input type="text" id="mpn" name="mpn"
                value="<%= product?.mpn || '' %>" placeholder="e.g. JM-BROOK-60-WW">
            </div>
            <div class="adm-form-group">
              <label for="google_condition">Condition</label>
              <select id="google_condition" name="google_condition">
                <option value="new"          <%= (!product?.google_condition || product.google_condition==='new')         ? 'selected':'' %>>New</option>
                <option value="refurbished"  <%= product?.google_condition==='refurbished' ? 'selected':'' %>>Refurbished</option>
                <option value="used"         <%= product?.google_condition==='used'        ? 'selected':'' %>>Used</option>
              </select>
            </div>
          </div>

          <div class="adm-form-group">
            <label for="google_product_category">Google Product Category</label>
            <input type="text" id="google_product_category" name="google_product_category"
              value="<%= product?.google_product_category || '' %>"
              placeholder="e.g. Home & Garden > Bath > Vanities"
              list="gpc-list">
            <datalist id="gpc-list">
              <option value="Home &amp; Garden > Bath > Vanities">
              <option value="Home &amp; Garden > Bath > Bathroom Mirrors">
              <option value="Home &amp; Garden > Bath > Bathroom Faucets">
              <option value="Home &amp; Garden > Bath > Bathroom Accessories">
              <option value="Home &amp; Garden > Bath > Bathtubs">
              <option value="Home &amp; Garden > Bath > Showers">
              <option value="Home &amp; Garden > Bath > Toilets &amp; Bidets">
              <option value="Home &amp; Garden > Lighting">
            </datalist>
            <span class="adm-form-hint">Use Google's <a href="https://support.google.com/merchants/answer/6324436" target="_blank">product taxonomy</a></span>
          </div>

          <div class="adm-form-row adm-form-row--3">
            <div class="adm-form-group">
              <label for="color">Color</label>
              <input type="text" id="color" name="color"
                value="<%= product?.color || '' %>" placeholder="e.g. White">
            </div>
            <div class="adm-form-group">
              <label for="material">Material</label>
              <input type="text" id="material" name="material"
                value="<%= product?.material || '' %>" placeholder="e.g. Solid Wood">
            </div>
            <div class="adm-form-group">
              <label for="pattern">Pattern</label>
              <input type="text" id="pattern" name="pattern"
                value="<%= product?.pattern || '' %>" placeholder="e.g. Solid">
            </div>
          </div>

          <div class="adm-form-row">
            <div class="adm-form-group">
              <label for="age_group">Age Group</label>
              <select id="age_group" name="age_group">
                <option value="">— None —</option>
                <% ['newborn','infant','toddler','kids','adult','all ages'].forEach(function(ag) { %>
                <option value="<%= ag %>" <%= product?.age_group===ag ? 'selected':'' %>><%= ag.charAt(0).toUpperCase()+ag.slice(1) %></option>
                <% }); %>
              </select>
            </div>
            <div class="adm-form-group">
              <label for="gender">Gender</label>
              <select id="gender" name="gender">
                <option value="">— None —</option>
                <option value="male"   <%= product?.gender==='male'   ? 'selected':'' %>>Male</option>
                <option value="female" <%= product?.gender==='female' ? 'selected':'' %>>Female</option>
                <option value="unisex" <%= product?.gender==='unisex' ? 'selected':'' %>>Unisex</option>
              </select>
            </div>
          </div>

          <div class="adm-form-row">
            <div class="adm-form-group">
              <label for="shipping_label">Shipping Label</label>
              <input type="text" id="shipping_label" name="shipping_label"
                value="<%= product?.shipping_label || '' %>" placeholder="e.g. bulky">
            </div>
            <div class="adm-form-group">
              <label for="custom_label_0">Custom Label 0</label>
              <input type="text" id="custom_label_0" name="custom_label_0"
                value="<%= product?.custom_label_0 || '' %>" placeholder="Custom segmentation">
            </div>
          </div>

          <div class="adm-form-row adm-form-row--3">
            <div class="adm-form-group">
              <label for="custom_label_1">Custom Label 1</label>
              <input type="text" id="custom_label_1" name="custom_label_1"
                value="<%= product?.custom_label_1 || '' %>">
            </div>
            <div class="adm-form-group">
              <label for="custom_label_2">Custom Label 2</label>
              <input type="text" id="custom_label_2" name="custom_label_2"
                value="<%= product?.custom_label_2 || '' %>">
            </div>
            <div class="adm-form-group">
              <label for="custom_label_3">Custom Label 3</label>
              <input type="text" id="custom_label_3" name="custom_label_3"
                value="<%= product?.custom_label_3 || '' %>">
            </div>
          </div>

          <div class="adm-form-row">
            <div class="adm-form-group">
              <label for="custom_label_4">Custom Label 4</label>
              <input type="text" id="custom_label_4" name="custom_label_4"
                value="<%= product?.custom_label_4 || '' %>">
            </div>
            <div class="adm-form-group">
              <label for="excluded_destinations">Excluded Destinations</label>
              <input type="text" id="excluded_destinations" name="excluded_destinations"
                value="<%= product?.excluded_destinations || '' %>"
                placeholder="e.g. Shopping_ads">
            </div>
          </div>

          <div class="adm-form-group">
            <label for="ads_redirect">Ads Redirect URL</label>
            <input type="url" id="ads_redirect" name="ads_redirect"
              value="<%= product?.ads_redirect || '' %>"
              placeholder="https://…">
            <span class="adm-form-hint">Override landing page URL for Google ads</span>
          </div>

          <div class="adm-form-group">
            <label class="adm-checkbox-label">
              <input type="hidden" name="identifier_exists" value="0">
              <input type="checkbox" name="identifier_exists" value="1"
                <%= (product?.identifier_exists == null || product?.identifier_exists == 1) ? 'checked' : '' %>>
              Has GTIN / MPN (identifier_exists)
            </label>
            <span class="adm-form-hint">Uncheck for custom/handmade products with no barcode or MPN — tells Google not to penalize missing identifiers</span>
          </div>
        </div>

      </div><!-- /.adm-form-main -->

      <!-- ══ RIGHT COLUMN ═════════════════════════════════════════ -->
      <div class="adm-form-side">

        <!-- ── Status & Flags ────────────────────────────────── -->
        <div class="adm-card">
          <h2 class="adm-card-title">Status</h2>
          <div class="adm-form-group">
            <label for="is_active">Store Visibility</label>
            <select id="is_active" name="is_active">
              <option value="1" <%= (!product || product.is_active) ? 'selected' : '' %>>Active — visible in store</option>
              <option value="0" <%= (product && !product.is_active) ? 'selected' : '' %>>Inactive — hidden from store</option>
            </select>
          </div>
          <div class="adm-form-group">
            <label for="status">Product Status</label>
            <select id="status" name="status">
              <option value="active"         <%= (!product?.status || product.status === 'active')          ? 'selected' : '' %>>Active</option>
              <option value="coming_soon"    <%= product?.status === 'coming_soon'    ? 'selected' : '' %>>Coming Soon</option>
              <option value="special_order"  <%= product?.status === 'special_order'  ? 'selected' : '' %>>Special Order</option>
              <option value="discontinued"   <%= product?.status === 'discontinued'   ? 'selected' : '' %>>Discontinued</option>
            </select>
          </div>
          <div class="adm-form-group">
            <label for="release_date">Release / Available Date</label>
            <input type="date" id="release_date" name="release_date"
              value="<%= product?.release_date ? String(product.release_date).slice(0,10) : '' %>">
          </div>
          <div style="display:flex;flex-direction:column;gap:10px;margin-top:8px">
            <label class="adm-toggle-label">
              <input type="checkbox" name="is_featured" value="1"
                <%= product?.is_featured ? 'checked' : '' %>> Featured Product
            </label>
            <label class="adm-toggle-label">
              <input type="checkbox" name="is_new" value="1"
                <%= product?.is_new ? 'checked' : '' %>> New Arrival
            </label>
            <label class="adm-toggle-label">
              <input type="checkbox" name="prop65" value="1"
                <%= product?.prop65 ? 'checked' : '' %>>
              Prop 65 Warning Required
            </label>
          </div>
          <% if (product?.source_flag && product.source_flag !== 'manual') { %>
          <div class="adm-form-group" style="margin-top:14px">
            <label>Data Source</label>
            <p class="adm-source adm-source--<%= product.source_flag %>"><%= product.source_flag %></p>
            <span class="adm-form-hint">Synced fields may be overwritten on next sync</span>
          </div>
          <% } %>
        </div>

        <!-- ── Inventory ─────────────────────────────────────── -->
        <div class="adm-card">
          <h2 class="adm-card-title">Inventory</h2>
          <div class="adm-form-group">
            <label for="qty_on_hand">Qty on Hand</label>
            <input type="number" id="qty_on_hand" name="qty_on_hand" min="0" step="1"
              value="<%= product?.qty_on_hand ?? 0 %>">
          </div>
          <% if (!isNew) { %>
          <div class="adm-form-group">
            <label>Qty Reserved</label>
            <p style="margin:4px 0;font-size:.95rem;color:#555"><%= product?.qty_reserved ?? 0 %></p>
            <span class="adm-form-hint">Held in open orders — auto-managed</span>
          </div>
          <% } %>
          <div class="adm-form-group">
            <label for="reorder_point">Reorder Point</label>
            <input type="number" id="reorder_point" name="reorder_point" min="0" step="1"
              value="<%= product?.reorder_point ?? 0 %>">
            <span class="adm-form-hint">Alert when stock falls below this level</span>
          </div>
          <div style="display:flex;flex-direction:column;gap:10px;margin-top:4px">
            <label class="adm-toggle-label">
              <input type="checkbox" name="allow_backorder" value="1"
                <%= product?.allow_backorder ? 'checked' : '' %>>
              Allow backorders (show "Add to Cart" when out of stock)
            </label>
          </div>
        </div>

        <!-- ── Images ────────────────────────────────────────── -->
        <div class="adm-card">
          <h2 class="adm-card-title">Images</h2>

          <!-- Primary image URL (direct column — fast fallback) -->
          <div class="adm-form-group">
            <label for="primary_image_url">Primary Image URL</label>
            <input type="url" id="primary_image_url" name="primary_image_url"
              value="<%= product?.primary_image_url || '' %>"
              placeholder="https://…/image.jpg">
            <span class="adm-form-hint">Used as fallback if no uploaded image is set as primary</span>
          </div>

          <!-- Additional image URLs (image_2 – image_7) -->
          <p class="adm-card-subtitle" style="margin-top:12px">Additional Image URLs</p>
          <% for (var _imgN = 2; _imgN <= 7; _imgN++) { %>
          <div class="adm-form-group" style="margin-bottom:8px">
            <label for="image_<%= _imgN %>_url">Image <%= _imgN %> URL</label>
            <input type="url" id="image_<%= _imgN %>_url" name="image_<%= _imgN %>_url"
              value="<%= product?.['image_' + _imgN + '_url'] || '' %>"
              placeholder="https://…/image-<%= _imgN %>.jpg">
          </div>
          <% } %>

          <% if (isNew) { %>
          <p class="adm-form-hint">Save the product first, then upload images below.</p>
          <% } else { %>
          <%
            var _imgs = (typeof productImages !== 'undefined') ? productImages : [];
          %>
          <% if (_imgs.length) { %>
          <div class="adm-img-grid">
            <% _imgs.forEach(function(img) { %>
            <div class="adm-img-thumb <%= img.is_primary ? 'adm-img-thumb--primary' : '' %>">
              <img src="<%= img.url %>" alt="<%= img.alt_text || '' %>">
              <% if (img.is_primary) { %><span class="adm-img-primary-badge">Primary</span><% } %>
              <div class="adm-img-actions">
                <% if (!img.is_primary) { %>
                <form method="POST" action="/admin/products/<%= product.id %>/images/<%= img.id %>/primary" style="display:inline">
                  <button type="submit" class="adm-img-btn" title="Set as primary">★</button>
                </form>
                <% } %>
                <form method="POST" action="/admin/products/<%= product.id %>/images/<%= img.id %>/delete" style="display:inline"
                  onsubmit="return confirm('Delete this image?')">
                  <button type="submit" class="adm-img-btn adm-img-btn--del" title="Delete">✕</button>
                </form>
              </div>
            </div>
            <% }) %>
          </div>
          <% } else { %>
          <p class="adm-form-hint" style="margin-bottom:10px">No gallery images yet.</p>
          <% } %>

          <form method="POST" action="/admin/products/<%= product.id %>/images"
            enctype="multipart/form-data" class="adm-img-upload-form">
            <label class="adm-img-drop" id="imgDropZone">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                <polyline points="17 8 12 3 7 8"/>
                <line x1="12" y1="3" x2="12" y2="15"/>
              </svg>
              <span id="imgDropLabel">Click or drag to upload</span>
              <input type="file" name="image_file" id="imgFileInput" accept="image/*" style="display:none">
            </label>
            <button type="submit" class="btn btn-sage" style="width:100%;margin-top:8px"
              id="imgUploadBtn" disabled>Upload Image</button>
          </form>
          <% } %>
        </div>

        <!-- ── SEO ───────────────────────────────────────────── -->
        <div class="adm-card">
          <h2 class="adm-card-title">SEO</h2>
          <div class="adm-form-group">
            <label for="meta_title">Meta Title</label>
            <input type="text" id="meta_title" name="meta_title"
              value="<%= product?.meta_title || '' %>" placeholder="Defaults to product name" maxlength="255">
            <span class="adm-form-hint"><span id="metaTitleCount">0</span> / 60 chars recommended</span>
          </div>
          <div class="adm-form-group">
            <label for="meta_desc">Meta Description</label>
            <textarea id="meta_desc" name="meta_desc" rows="3" maxlength="500"
              placeholder="Defaults to short description"><%= product?.meta_desc || '' %></textarea>
            <span class="adm-form-hint"><span id="metaDescCount">0</span> / 160 chars recommended</span>
          </div>
        </div>

        <!-- ── Data Source (read-only) ───────────────────────── -->
        <% if (!isNew && product) { %>
        <div class="adm-card">
          <h2 class="adm-card-title">Data Source</h2>
          <div class="adm-source-grid">
            <span class="adm-source-label">Source</span>
            <span><%= product.source_flag || '—' %></span>
            <span class="adm-source-label">RFLPOS ID</span>
            <span><%= product.rflpos_item_id || '—' %></span>
            <span class="adm-source-label">Salsify ID</span>
            <span><%= product.salsify_id || '—' %></span>
            <span class="adm-source-label">Product ID</span>
            <span><%= product.id %></span>
            <span class="adm-source-label">Created</span>
            <span><%= product.created_at ? new Date(product.created_at).toLocaleDateString() : '—' %></span>
            <span class="adm-source-label">Updated</span>
            <span><%= product.updated_at ? new Date(product.updated_at).toLocaleDateString() : '—' %></span>
          </div>
        </div>
        <% } %>

        <!-- ── Documents & Downloads ────────────────────────── -->
        <div class="adm-card">
          <h2 class="adm-card-title">Documents &amp; Downloads</h2>

          <% if (!isNew && product) { %>
          <%
            var _docs = (typeof productDocs !== 'undefined') ? productDocs : [];
            var _docTypeLabels = {
              spec_sheet:'Spec Sheet', installation_guide:'Installation Guide',
              warranty:'Warranty', rebate_form:'Rebate Form',
              cad_drawing:'CAD Drawing', measurement_guide:'Measurement Guide',
              care_guide:'Care Guide', other:'Other'
            };
          %>

          <% if (_docs.length) { %>
          <div class="adm-doc-list">
            <% _docs.forEach(function(doc) { %>
            <div class="adm-doc-row">
              <div class="adm-doc-info">
                <span class="adm-doc-type"><%= _docTypeLabels[doc.doc_type] || doc.doc_type %></span>
                <a href="<%= doc.url %>" target="_blank" class="adm-doc-link" title="<%= doc.url %>">
                  <%= doc.label || doc.url.split('/').pop() %>
                </a>
              </div>
              <form method="POST" action="/admin/products/<%= product.id %>/docs/<%= doc.id %>/delete"
                onsubmit="return confirm('Remove this document?')" style="display:inline">
                <button type="submit" class="adm-doc-del" title="Remove">✕</button>
              </form>
            </div>
            <% }); %>
          </div>
          <% } else { %>
          <p class="adm-form-hint" style="margin-bottom:12px">No documents yet.</p>
          <% } %>

          <!-- Add document form -->
          <form method="POST" action="/admin/products/<%= product.id %>/docs"
            enctype="multipart/form-data" class="adm-doc-add-form">

            <div class="adm-form-row" style="margin-bottom:8px">
              <div class="adm-form-group" style="margin-bottom:0">
                <label>Doc Type</label>
                <select name="doc_type" class="adm-doc-type-sel">
                  <% Object.entries(_docTypeLabels).forEach(function(kv) { %>
                  <option value="<%= kv[0] %>"><%= kv[1] %></option>
                  <% }); %>
                </select>
              </div>
              <div class="adm-form-group" style="margin-bottom:0">
                <label>Label (optional)</label>
                <input type="text" name="label" placeholder="Custom label…">
              </div>
            </div>

            <div class="adm-form-group" style="margin-bottom:8px">
              <label>Paste URL</label>
              <input type="url" name="doc_url" placeholder="https://…/spec-sheet.pdf">
            </div>

            <div class="adm-doc-or">— or upload a file —</div>

            <div class="adm-doc-upload-row">
              <label class="adm-doc-file-label">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                  <polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/>
                </svg>
                <span id="docFileLabel">Choose PDF / Word / image</span>
                <input type="file" name="doc_file" id="docFileInput"
                  accept=".pdf,.doc,.docx,.jpg,.jpeg,.png" style="display:none">
              </label>
              <button type="submit" class="btn btn-sage" style="white-space:nowrap">Add Document</button>
            </div>
          </form>

          <% } else { %>
          <p class="adm-form-hint">Save the product first, then add documents.</p>
          <% } %>
        </div>

      </div><!-- /.adm-form-side -->
    </div><!-- /.adm-form-grid -->

    <div class="adm-form-actions">
      <button type="submit" class="btn btn-primary"><%= isNew ? 'Create Product' : 'Save Changes' %></button>
      <a href="/admin/products" class="btn btn-outline">Cancel</a>
      <% if (!isNew && product) { %>
      <form method="POST" action="/admin/products/<%= product.id %>/delete" style="margin-left:auto"
        onsubmit="return confirm('Permanently delete this product?')">
        <button type="submit" class="btn" style="color:#c00;border-color:#c00">Delete Product</button>
      </form>
      <% } %>
    </div>
  </form>
</div>

<script>
(function() {
  // Auto-slug from name
  const nameInput = document.getElementById('name');
  const slugInput = document.getElementById('slug');
  nameInput?.addEventListener('input', () => {
    if (!slugInput.value.trim()) {
      slugInput.placeholder = nameInput.value.toLowerCase().replace(/[^a-z0-9]+/g,'-').replace(/^-|-$/g,'');
    }
  });

  // SEO char counters
  const metaTitle = document.getElementById('meta_title');
  const metaDesc  = document.getElementById('meta_desc');
  const mtCount   = document.getElementById('metaTitleCount');
  const mdCount   = document.getElementById('metaDescCount');
  function updateCount(input, el) {
    if (input && el) { el.textContent = input.value.length; input.addEventListener('input', () => el.textContent = input.value.length); }
  }
  updateCount(metaTitle, mtCount);
  updateCount(metaDesc,  mdCount);

  // Dynamic spec rows
  const specsList  = document.getElementById('specs-list');
  const addSpecBtn = document.getElementById('add-spec-btn');

  function nextIdx() { return specsList.querySelectorAll('.spec-row-edit').length; }

  function addRow(key='', text='', num='') {
    const i = nextIdx();
    const div = document.createElement('div');
    div.className = 'spec-row-edit';
    div.innerHTML = `
      <input type="text"   name="spec[${i}][key]"  value="${key}"  placeholder="attr_key" list="spec-keys" class="spec-key-input">
      <input type="text"   name="spec[${i}][text]" value="${text}" placeholder="Text value">
      <input type="number" name="spec[${i}][num]"  value="${num}"  placeholder="Numeric value" step="any">
      <button type="button" class="spec-remove-btn" title="Remove">✕</button>`;
    specsList.appendChild(div);
    div.querySelector('.spec-key-input').focus();
  }

  addSpecBtn?.addEventListener('click', () => addRow());
  specsList?.addEventListener('click', e => {
    if (e.target.classList.contains('spec-remove-btn')) {
      e.target.closest('.spec-row-edit').remove();
      specsList.querySelectorAll('.spec-row-edit').forEach((row, idx) => {
        row.querySelectorAll('[name]').forEach(inp => {
          inp.name = inp.name.replace(/spec\[\d+\]/, `spec[${idx}]`);
        });
      });
    }
  });

  // Doc file input label update
  const docFileInput = document.getElementById('docFileInput');
  const docFileLabel = document.getElementById('docFileLabel');
  if (docFileInput && docFileLabel) {
    docFileInput.addEventListener('change', () => {
      docFileLabel.textContent = docFileInput.files[0]?.name || 'Choose PDF / Word / image';
    });
  }

  // Image upload drop zone
  const fileInput = document.getElementById('imgFileInput');
  const dropZone  = document.getElementById('imgDropZone');
  const dropLabel = document.getElementById('imgDropLabel');
  const uploadBtn = document.getElementById('imgUploadBtn');
  if (fileInput) {
    dropZone.addEventListener('click', () => fileInput.click());
    dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('is-over'); });
    dropZone.addEventListener('dragleave', () => dropZone.classList.remove('is-over'));
    dropZone.addEventListener('drop', e => {
      e.preventDefault(); dropZone.classList.remove('is-over');
      if (e.dataTransfer.files[0]) { fileInput.files = e.dataTransfer.files; fileInput.dispatchEvent(new Event('change')); }
    });
    fileInput.addEventListener('change', () => {
      if (fileInput.files[0]) { dropLabel.textContent = fileInput.files[0].name; uploadBtn.disabled = false; }
    });
  }
})();
</script>

<style>
.adm-card-subtitle { font-size:.75rem; font-weight:600; text-transform:uppercase; letter-spacing:.06em; color:#888; margin:0 0 10px; }
.adm-form-row--3 { grid-template-columns: repeat(3,1fr); }
.adm-form-row--4 { grid-template-columns: repeat(4,1fr); }
.spec-row-edit { display:grid; grid-template-columns:1fr 1.4fr .8fr auto; gap:8px; margin-bottom:8px; align-items:center; }
.spec-remove-btn { background:none; border:1px solid #ddd; border-radius:6px; cursor:pointer; color:#999; padding:4px 8px; font-size:.85rem; }
.spec-remove-btn:hover { color:#c00; border-color:#c00; }
.adm-img-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:10px; margin-bottom:14px; }
.adm-img-thumb { position:relative; border:2px solid #ddd; border-radius:8px; overflow:hidden; aspect-ratio:1; background:#f5f5f5; }
.adm-img-thumb--primary { border-color:var(--amber,#C68B2F); }
.adm-img-thumb img { width:100%; height:100%; object-fit:cover; display:block; }
.adm-img-primary-badge { position:absolute; top:4px; left:4px; background:var(--amber,#C68B2F); color:#fff; font-size:.65rem; font-weight:700; padding:2px 6px; border-radius:4px; text-transform:uppercase; }
.adm-img-actions { position:absolute; bottom:0; left:0; right:0; background:rgba(0,0,0,.55); display:flex; justify-content:center; gap:6px; padding:6px; opacity:0; transition:opacity .15s; }
.adm-img-thumb:hover .adm-img-actions { opacity:1; }
.adm-img-btn { background:rgba(255,255,255,.9); border:none; border-radius:4px; cursor:pointer; padding:3px 8px; font-size:.8rem; color:#333; }
.adm-img-btn--del:hover { background:#c00; color:#fff; }
.adm-img-drop { display:flex; flex-direction:column; align-items:center; gap:8px; border:2px dashed #ddd; border-radius:8px; padding:18px 12px; cursor:pointer; text-align:center; color:#888; font-size:.85rem; transition:border-color .15s,background .15s; }
.adm-img-drop:hover,.adm-img-drop.is-over { border-color:var(--sage,#7A9E7E); background:#f7faf7; color:#444; }
.adm-toggle-label { display:flex; align-items:center; gap:7px; font-size:.875rem; cursor:pointer; }
.adm-toggle-label input[type=checkbox] { width:15px; height:15px; cursor:pointer; }
.adm-flash { padding:10px 16px; border-radius:8px; margin-bottom:16px; font-size:.875rem; }
.adm-flash--success { background:#f0faf2; border:1px solid #7A9E7E; color:#2d6a38; }
.adm-flash--error   { background:#fff5f5; border:1px solid #c00; color:#900; }
.adm-source-grid { display:grid; grid-template-columns:auto 1fr; gap:6px 12px; font-size:.8rem; }
.adm-source-label { color:#888; font-weight:600; white-space:nowrap; }

/* Documents */
.adm-doc-list { display:flex; flex-direction:column; gap:6px; margin-bottom:14px; }
.adm-doc-row { display:flex; align-items:flex-start; justify-content:space-between; gap:8px; padding:7px 10px; background:#f7f5f0; border-radius:7px; border:1px solid #e8e5e1; }
.adm-doc-info { flex:1; min-width:0; }
.adm-doc-type { display:block; font-size:.68rem; font-weight:700; text-transform:uppercase; letter-spacing:.06em; color:#888; margin-bottom:2px; }
.adm-doc-link { font-size:.8rem; color:var(--color-amber,#C68B2F); text-decoration:none; word-break:break-all; }
.adm-doc-link:hover { text-decoration:underline; }
.adm-doc-del { background:none; border:none; cursor:pointer; color:#bbb; font-size:.9rem; padding:2px 6px; border-radius:4px; flex-shrink:0; }
.adm-doc-del:hover { color:#c00; background:#fff0f0; }
.adm-doc-add-form { margin-top:8px; }
.adm-doc-or { text-align:center; color:#aaa; font-size:.78rem; margin:8px 0; }
.adm-doc-upload-row { display:flex; gap:8px; align-items:center; }
.adm-doc-file-label { flex:1; display:flex; align-items:center; gap:7px; border:1px dashed #ccc; border-radius:7px; padding:7px 10px; cursor:pointer; font-size:.8rem; color:#666; min-width:0; transition:border-color .15s; }
.adm-doc-file-label:hover { border-color:var(--color-sage,#7A9E7E); color:#333; }
.adm-doc-type-sel { font-size:.8rem; }
</style>
