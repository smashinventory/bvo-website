<!-- Category header -->
<div class="cat-header">
  <div class="cat-header-inner">
    <h1><%= category.name %></h1>
    <% if (category.description) { %><p><%= category.description %></p><% } %>
  </div>
</div>

<!-- Breadcrumb -->
<div class="breadcrumb">
  <a href="/">Home</a> &rsaquo;
  <a href="/collections">Collections</a> &rsaquo;
  <%= category.name %>
</div>

<!-- Mobile filter drawer overlay -->
<div class="filter-overlay" id="filterOverlay" aria-hidden="true"></div>

<!-- Layout: sidebar + main -->
<div class="listing-layout">

  <!-- ── Filter sidebar ──────────────────────────────────────────── -->
  <aside class="filter-panel" aria-label="Filter products">
    <form method="GET" id="filter-form">
      <input type="hidden" name="sort" value="<%= sort %>">
      <%/* Preserve all color params when any other filter fires form.submit() */%>
      <% colorFamilyActive.forEach(function(f) { %><input type="hidden" name="color_family" value="<%= f %>"><% }) %>
      <% colorExactActive.forEach(function(e) { %><input type="hidden" name="color_exact" value="<%= e %>"><% }) %>
      <% hwColorFamilyActive.forEach(function(f) { %><input type="hidden" name="hw_color_family" value="<%= f %>"><% }) %>
      <% hwColorExactActive.forEach(function(e) { %><input type="hidden" name="hw_color_exact" value="<%= e %>"><% }) %>

      <div class="filter-header">
        <h3>Filters</h3>
        <% if (hasActiveFilters) { %>
        <a href="/collections/<%= category.slug %>" class="filter-clear-top">Clear all</a>
        <% } %>
        <button type="button" class="filter-close-btn" id="filterCloseBtn" aria-label="Close filters">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>

      <%/*
       * DYNAMIC FILTER GROUPS
       * Each attribute_definition drives one collapsible group.
       * filter_type:
       *   checkbox     → list of checkboxes (brand, style, mount_type …)
       *   color_swatch → checkbox + color circle (cabinet_finish, hardware_finish, finish)
       *   range        → min/max number inputs (size_in, width_in …)
       *   boolean      → single Yes/No toggle (sink_included, has_led …)
       *
       * Groups with no available options are hidden automatically.
       * Brand is always first (comes from availableBrands, not attribute_definitions).
       */%>

      <!-- ── Brand (always first) ──────────────────────────────── -->
      <% if (availableBrands.length > 0) { %>
      <%   var brandActive = brands.length > 0; %>
      <div class="filter-group">
        <button type="button" class="filter-group-toggle" aria-expanded="<%= brandActive ? 'true' : 'false' %>">
          Brand
          <% if (brandActive) { %><span class="filter-badge"><%= brands.length %></span><% } %>
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="filter-group-body<%= brandActive ? '' : ' is-collapsed' %>">
          <% availableBrands.forEach(function(b) { %>
          <label class="filter-option">
            <input type="checkbox" name="brand" value="<%= b %>"
              <%= brands.includes(b) ? 'checked' : '' %>>
            <span><%= b %></span>
          </label>
          <% }) %>
        </div>
      </div>
      <% } %>

      <%
      /*
       * Attribute-driven filter groups.
       * Skip 'brand' (handled above).
       * For each def, we look up available values from the placeholder data
       * (in production these come from getAttributeValues() pre-fetched in controller;
       *  here we derive them inline from the products array for the fallback case).
       *
       * Finish group label is context-aware:
       *   cabinet_finish → "Cabinet Color"
       *   hardware_finish → "Hardware Finish"
       *   finish (mirrors/faucets/lighting) → category-specific display_name
       */

      %>

      <% attributeDefs.forEach(function(def) {
          if (def.attr_key === 'brand') return; // handled above

          var activeVals = attrFilters[def.attr_key] || [];
          var rangeActive = rangeFilters[def.attr_key] || {};

          /* Determine if group should start expanded:
             - expanded if any value is active
             - expanded if it's the first 3 groups
             - collapsed otherwise (user can open)      */
          var isExpanded = activeVals.length > 0 ||
                           Object.keys(rangeActive).length > 0 ||
                           def.sort_order <= 3;
      %>

      <% if (def.filter_type === 'checkbox') { %>
      <%   /* Enumerate values from product set OR hardcoded lists per key */ %>
      <%
        /* Use only values that actually exist in products for this category.
           availableAttrValues is pre-fetched by the controller from the DB
           (or derived from the placeholder array in offline mode). */
        var checkOptions = availableAttrValues[def.attr_key] || [];
        if (!checkOptions.length) return; /* hide groups with no products */
      %>
      <div class="filter-group">
        <button type="button" class="filter-group-toggle" aria-expanded="<%= isExpanded %>">
          <%= def.display_name %>
          <% if (activeVals.length) { %><span class="filter-badge"><%= activeVals.length %></span><% } %>
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="filter-group-body<%= isExpanded ? '' : ' is-collapsed' %>">
          <% checkOptions.forEach(function(opt) {
               /* Pretty-print product_type slugs */
               var label = def.attr_key === 'product_type'
                 ? opt.replace(/-/g, ' ').replace(/\b\w/g, function(c){ return c.toUpperCase(); })
                 : opt;
          %>
          <label class="filter-option">
            <input type="checkbox" name="<%= def.attr_key %>" value="<%= opt %>"
              <%= activeVals.includes(opt) ? 'checked' : '' %>>
            <span><%= label %></span>
          </label>
          <% }) %>
        </div>
      </div>

      <% } else if (def.filter_type === 'color_swatch' && (def.attr_key === 'cabinet_finish' || def.attr_key === 'finish')) { %>
      <%
        /*
         * Primary Color — family swatch + multi-select sub-chip UI.
         *   cabinet_finish → cabinet color families (vanities)
         *   finish         → metallic finish families (mirrors, faucets, lighting, accessories)
         *
         * colorFamiliesConfig, colorFamilyActive, colorExactActive come from
         * collectionsController and carry precomputed isActive/isOpen/activeExact
         * per family, scoped to the correct family type for this category.
         *
         * availFinishes is sourced from products.color (controller-passed).
         * Do NOT override it here from availableAttrValues.
         */
        var hasAnyColorActive = colorFamilyActive.length > 0 || colorExactActive.length > 0;
        var colorBadgeCount = colorFamilyActive.length + (colorExactActive.length > 0 ? 1 : 0);

        // Filter families to those with at least one product in this category.
        // Case-insensitive so 'gray oak' matches 'Gray Oak' regardless of DB casing.
        var availFinishesLower = availFinishes.map(function(f) { return f.toLowerCase(); });
        var visibleFamilies = colorFamiliesConfig.filter(function(fam) {
          if (!availFinishes.length) return true; // no products yet — show all families
          return fam.members.some(function(m) { return availFinishesLower.includes(m.toLowerCase()); });
        });
      %>
      <% if (visibleFamilies.length > 0) { %>
      <div class="filter-group" id="color-filter-group">
        <button type="button" class="filter-group-toggle"
          aria-expanded="<%= (hasAnyColorActive || isExpanded) ? 'true' : 'false' %>">
          <%= def.display_name %>
          <% if (colorBadgeCount > 0) { %><span class="filter-badge"><%= colorBadgeCount %></span><% } %>
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="filter-group-body<%= (hasAnyColorActive || isExpanded) ? '' : ' is-collapsed' %>">

          <!-- Family swatches -->
          <div class="color-family-row" id="color-family-row">
            <% visibleFamilies.forEach(function(fam) { %>
            <div class="color-family-sw<%= fam.isActive ? ' is-active' : '' %>"
                 data-color-key="<%= fam.key %>"
                 title="<%= fam.label %>"
                 role="button" tabindex="0"
                 aria-pressed="<%= fam.isActive ? 'true' : 'false' %>">
              <span class="color-sw-dot<%= fam.woodGrain ? ' swatch--wood-grain' : '' %>"
                    style="background:<%= fam.hex %>;border-color:<%= fam.border %>"></span>
              <span class="color-sw-name"><%= fam.label %></span>
            </div>
            <% }) %>
          </div>

          <!-- Sub-chip rows — one per family, shown when family is active -->
          <% visibleFamilies.forEach(function(fam) {
               /* Filter sub-chip options to members that actually exist in products */
               var subOptions = availFinishes.length
                 ? fam.members.filter(function(m) { return availFinishes.includes(m); })
                 : fam.members;
               if (!subOptions.length) return;
          %>
          <div class="color-sub-row<%= fam.isOpen ? ' is-open' : '' %>"
               id="color-sub-<%= fam.key %>">
            <div class="color-sub-hint">↓ Narrow by shade (optional):</div>
            <div class="color-sub-chips">
              <% subOptions.forEach(function(member) {
                   var chipActive = colorExactActive.includes(member);
              %>
              <button type="button"
                      class="color-sub-chip<%= chipActive ? ' is-active' : '' %>"
                      data-color-exact="<%= member %>"
                      data-color-family="<%= fam.key %>">
                <%= member %>
              </button>
              <% }) %>
            </div>
          </div>
          <% }) %>

        </div>
      </div>
      <% } %>

      <% } else if (def.filter_type === 'color_swatch' && def.attr_key === 'hardware_finish') { %>
      <%
        /*
         * Hardware Finish — secondary color layer for vanities.
         * Shown on vanities only; hwColorFamiliesConfig is [] for other categories.
         * Uses separate URL params: hw_color_family / hw_color_exact.
         * availHardwareFinishes comes from the controller (EAV hardware_finish values).
         */
        var hasAnyHwColorActive = hwColorFamilyActive.length > 0 || hwColorExactActive.length > 0;
        var hwColorBadgeCount = hwColorFamilyActive.length + (hwColorExactActive.length > 0 ? 1 : 0);
        var availHwLower = availHardwareFinishes.map(function(f) { return f.toLowerCase(); });
        var visibleHwFamilies = hwColorFamiliesConfig.filter(function(fam) {
          if (!availHardwareFinishes.length) return false;
          return fam.members.some(function(m) { return availHwLower.includes(m.toLowerCase()); });
        });
      %>
      <% if (visibleHwFamilies.length > 0) { %>
      <div class="filter-group" id="hw-color-filter-group">
        <button type="button" class="filter-group-toggle"
          aria-expanded="<%= (hasAnyHwColorActive || isExpanded) ? 'true' : 'false' %>">
          <%= def.display_name %>
          <% if (hwColorBadgeCount > 0) { %><span class="filter-badge"><%= hwColorBadgeCount %></span><% } %>
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="filter-group-body<%= (hasAnyHwColorActive || isExpanded) ? '' : ' is-collapsed' %>">

          <!-- HW Family swatches -->
          <div class="color-family-row" id="hw-color-family-row">
            <% visibleHwFamilies.forEach(function(fam) { %>
            <div class="color-family-sw<%= fam.isActive ? ' is-active' : '' %>"
                 data-hw-color-key="<%= fam.key %>"
                 title="<%= fam.label %>"
                 role="button" tabindex="0"
                 aria-pressed="<%= fam.isActive ? 'true' : 'false' %>">
              <span class="color-sw-dot"
                    style="background:<%= fam.hex %>;border-color:<%= fam.border %>"></span>
              <span class="color-sw-name"><%= fam.label %></span>
            </div>
            <% }) %>
          </div>

          <!-- HW Sub-chip rows — one per family, shown when family is active -->
          <% visibleHwFamilies.forEach(function(fam) {
               var subOptions = availHardwareFinishes.length
                 ? fam.members.filter(function(m) { return availHardwareFinishes.includes(m); })
                 : fam.members;
               if (!subOptions.length) return;
          %>
          <div class="color-sub-row<%= fam.isOpen ? ' is-open' : '' %>"
               id="hw-color-sub-<%= fam.key %>">
            <div class="color-sub-hint">↓ Narrow by finish (optional):</div>
            <div class="color-sub-chips">
              <% subOptions.forEach(function(member) {
                   var chipActive = hwColorExactActive.includes(member);
              %>
              <button type="button"
                      class="color-sub-chip<%= chipActive ? ' is-active' : '' %>"
                      data-hw-color-exact="<%= member %>"
                      data-hw-color-family="<%= fam.key %>">
                <%= member %>
              </button>
              <% }) %>
            </div>
          </div>
          <% }) %>

        </div>
      </div>
      <% } %>

      <% } else if (def.filter_type === 'color_swatch') { %>
      <% /* Unrecognized color_swatch key — skip to avoid rendering stale finishHex logic */ return; %>

      <% } else if (def.filter_type === 'range') { %>
      <div class="filter-group">
        <button type="button" class="filter-group-toggle" aria-expanded="<%= isExpanded %>">
          <%= def.display_name %>
          <% if (rangeActive.min != null || rangeActive.max != null) { %><span class="filter-badge">1</span><% } %>
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="filter-group-body<%= isExpanded ? '' : ' is-collapsed' %>">
          <% if (def.attr_key === 'size_in') { %>
          <%/* Size chip filter — styled labels over hidden checkboxes (same form
              * submission as other filters, no JS needed). availableSizes contains
              * only buckets with ≥1 product in the current filtered collection.
              * Canonical source: products.width_in via SIZE_BUCKETS (Rule 10). */
            var _activeSizes = attrFilters['size_in'] || [];
            var _chips = (typeof availableSizes !== 'undefined') ? availableSizes : [];
          %>
          <div class="size-chips">
            <% _chips.forEach(function(sz) {
                 var isActive = _activeSizes.indexOf(String(sz)) !== -1;
                 var chipLabel = sz === '20-' ? '20 & under'
                               : sz === '84+' ? '84 & over'
                               : sz + ' Inches';
            %>
            <label class="size-chip<%= isActive ? ' is-active' : '' %>">
              <input type="checkbox" name="<%= def.attr_key %>" value="<%= sz %>"
                <%= isActive ? 'checked' : '' %>
                style="position:absolute;opacity:0;pointer-events:none;width:0;height:0;">
              <span class="size-chip-label"><%= chipLabel %></span>
            </label>
            <% }) %>
          </div>
          <% } else { %>
          <div class="filter-price">
            <input type="number" name="<%= def.attr_key %>_min"
              placeholder="Min" value="<%= rangeActive.min != null ? rangeActive.min : '' %>" min="0">
            <span>–</span>
            <input type="number" name="<%= def.attr_key %>_max"
              placeholder="Max" value="<%= rangeActive.max != null ? rangeActive.max : '' %>" min="0">
          </div>
          <button type="submit" class="btn btn-sage btn-filter-apply">Apply</button>
          <% } %>
        </div>
      </div>

      <% } else if (def.filter_type === 'boolean') { %>
      <%   /* Only show boolean filter if at least one product has this attribute */
           if (!(availableAttrValues[def.attr_key] || []).length) return;
      %>
      <div class="filter-group">
        <button type="button" class="filter-group-toggle" aria-expanded="<%= isExpanded %>">
          <%= def.display_name %>
          <% if (activeVals.length) { %><span class="filter-badge">✓</span><% } %>
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="filter-group-body<%= isExpanded ? '' : ' is-collapsed' %>">
          <label class="filter-option">
            <input type="checkbox" name="<%= def.attr_key %>" value="Yes"
              <%= activeVals.includes('Yes') ? 'checked' : '' %>>
            <span>Yes</span>
          </label>
        </div>
      </div>
      <% } %>

      <% }) /* end attributeDefs.forEach */ %>

      <%/*
       * ── Model-group extra filter groups ──────────────────────────
       * For model-group categories (displayMode === 'model-group'),
       * attributeDefs is [] so the forEach above renders nothing.
       * We add Size chips and Cabinet Color explicitly here.
       * Brand and Price Range already render above/below via shared template vars.
       */%>
      <% if (typeof displayMode !== 'undefined' && displayMode === 'model-group') { %>

      <%/* ── Size chips (model-group) ──────────────────────────── */%>
      <% if (typeof availableSizes !== 'undefined' && availableSizes.length > 0) { %>
      <%   var _mgSizeActive = typeof activeSizes !== 'undefined' && activeSizes.length > 0; %>
      <div class="filter-group">
        <button type="button" class="filter-group-toggle"
          aria-expanded="<%= _mgSizeActive ? 'true' : 'false' %>">
          Size
          <% if (_mgSizeActive) { %><span class="filter-badge"><%= activeSizes.length %></span><% } %>
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="filter-group-body<%= _mgSizeActive ? '' : ' is-collapsed' %>">
          <div class="size-chips">
            <% availableSizes.forEach(function(sz) {
                 var isActive = (typeof activeSizes !== 'undefined') && activeSizes.indexOf(String(sz)) !== -1;
                 var chipLabel = sz === '20-' ? '20 & under' : sz === '84+' ? '84 & over' : sz + ' Inches';
            %>
            <label class="size-chip<%= isActive ? ' is-active' : '' %>">
              <input type="checkbox" name="size_in" value="<%= sz %>"
                <%= isActive ? 'checked' : '' %>
                style="position:absolute;opacity:0;pointer-events:none;width:0;height:0;">
              <span class="size-chip-label"><%= chipLabel %></span>
            </label>
            <% }) %>
          </div>
        </div>
      </div>
      <% } %>

      <%/* ── Cabinet Color (model-group) ──────────────────────── */%>
      <%
        var _mgHasColorActive = colorFamilyActive.length > 0 || colorExactActive.length > 0;
        var _mgColorBadge     = colorFamilyActive.length + (colorExactActive.length > 0 ? 1 : 0);
        var _mgFinishesLower      = availFinishes.map(function(f) { return f.toLowerCase(); });
        var _mgAvailFamilyKeys    = (typeof availColorFamilies !== 'undefined') ? availColorFamilies : [];
        var _mgVisibleFam         = colorFamiliesConfig.filter(function(fam) {
          if (!availFinishes.length && !_mgAvailFamilyKeys.length) return true;
          // Primary check: color_family key match (reliable — set by import pipeline)
          if (_mgAvailFamilyKeys.includes(fam.key)) return true;
          // Fallback: member-string match against products.color values
          return fam.members.some(function(m) { return _mgFinishesLower.includes(m.toLowerCase()); });
        });
      %>
      <% if (_mgVisibleFam.length > 0) { %>
      <div class="filter-group" id="color-filter-group">
        <button type="button" class="filter-group-toggle"
          aria-expanded="<%= _mgHasColorActive ? 'true' : 'false' %>">
          Cabinet Color
          <% if (_mgColorBadge > 0) { %><span class="filter-badge"><%= _mgColorBadge %></span><% } %>
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="filter-group-body<%= _mgHasColorActive ? '' : ' is-collapsed' %>">
          <!-- Family swatches -->
          <div class="color-family-row" id="color-family-row">
            <% _mgVisibleFam.forEach(function(fam) { %>
            <div class="color-family-sw<%= fam.isActive ? ' is-active' : '' %>"
                 data-color-key="<%= fam.key %>"
                 title="<%= fam.label %>"
                 role="button" tabindex="0"
                 aria-pressed="<%= fam.isActive ? 'true' : 'false' %>">
              <span class="color-sw-dot<%= fam.woodGrain ? ' swatch--wood-grain' : '' %>"
                    style="background:<%= fam.hex %>;border-color:<%= fam.border %>"></span>
              <span class="color-sw-name"><%= fam.label %></span>
            </div>
            <% }) %>
          </div>
          <!-- Sub-chip rows — shown when family is active -->
          <% _mgVisibleFam.forEach(function(fam) {
               var subOptions = availFinishes.length
                 ? fam.members.filter(function(m) { return availFinishes.includes(m); })
                 : fam.members;
               if (!subOptions.length) return;
          %>
          <div class="color-sub-row<%= fam.isOpen ? ' is-open' : '' %>"
               id="color-sub-<%= fam.key %>">
            <div class="color-sub-hint">↓ Narrow by shade (optional):</div>
            <div class="color-sub-chips">
              <% subOptions.forEach(function(member) {
                   var chipActive = colorExactActive.includes(member);
              %>
              <button type="button"
                      class="color-sub-chip<%= chipActive ? ' is-active' : '' %>"
                      data-color-exact="<%= member %>"
                      data-color-family="<%= fam.key %>">
                <%= member %>
              </button>
              <% }) %>
            </div>
          </div>
          <% }) %>
        </div>
      </div>
      <% } %>

      <% } /* end model-group filter groups */ %>

      <!-- ── Price Range (always last) ─────────────────────────── -->
      <div class="filter-group">
        <button type="button" class="filter-group-toggle"
          aria-expanded="<%= (minPrice != null || maxPrice != null) ? 'true' : 'false' %>">
          Price Range
          <% if (minPrice != null || maxPrice != null) { %><span class="filter-badge">1</span><% } %>
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="filter-group-body<%= (minPrice != null || maxPrice != null) ? '' : ' is-collapsed' %>">
          <div class="filter-price">
            <input type="number" name="min_price" placeholder="Min $"
              value="<%= minPrice != null ? minPrice : '' %>"
              min="0" step="1">
            <span>–</span>
            <input type="number" name="max_price" placeholder="Max $"
              value="<%= maxPrice != null ? maxPrice : '' %>"
              min="0" step="1">
          </div>
          <button type="submit" class="btn btn-sage btn-filter-apply">Apply Price</button>
        </div>
      </div>

    </form>
  </aside>

  <!-- ── Listing main ─────────────────────────────────────────────── -->
  <div class="listing-main">

    <!-- Toolbar -->
    <div class="listing-toolbar">
      <button type="button" class="mobile-filter-btn" id="mobileFilterBtn" aria-label="Open filters">
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6"/><line x1="7" y1="12" x2="17" y2="12"/><line x1="10" y1="18" x2="14" y2="18"/>
        </svg>
        Filters<% if (hasActiveFilters) { %> <span class="mobile-filter-dot">●</span><% } %>
      </button>
      <p class="listing-count">
        <% if (typeof displayMode !== 'undefined' && displayMode === 'model-group') { %>
          <%= total %> model collection<%= total !== 1 ? 's' : '' %>
          <% if ((activeBrands || []).length) { %> · <strong><%= (activeBrands || []).join(', ') %></strong><% } %>
        <% } else { %>
          <%= total %> product<%= total !== 1 ? 's' : '' %>
          <% if (brands.length) { %> · <strong><%= brands.join(', ') %></strong><% } %>
        <% } %>
        <% if (hasActiveFilters) { %>
        <a href="/collections/<%= category.slug %>" class="toolbar-clear-link">Clear filters</a>
        <% } %>
      </p>
      <% if (!(typeof displayMode !== 'undefined' && displayMode === 'model-group')) { %>
      <form method="GET" id="sort-form">
        <!-- Preserve all active filters when sorting -->
        <% brands.forEach(function(b) { %><input type="hidden" name="brand" value="<%= b %>"><% }) %>
        <% productTypes.forEach(function(t) { %><input type="hidden" name="type" value="<%= t %>"><% }) %>
        <% Object.entries(attrFilters).forEach(function(entry) {
             var key = entry[0], vals = entry[1];
             vals.forEach(function(v) { %><input type="hidden" name="<%= key %>" value="<%= v %>"><% }) %>
        <% }) %>
        <% Object.entries(rangeFilters).forEach(function(entry) {
             var key = entry[0], range = entry[1];
             if (range.min != null) { %><input type="hidden" name="<%= key %>_min" value="<%= range.min %>"><% }
             if (range.max != null) { %><input type="hidden" name="<%= key %>_max" value="<%= range.max %>"><% }
           }) %>
        <% if (minPrice != null) { %><input type="hidden" name="min_price" value="<%= minPrice %>"><% } %>
        <% if (maxPrice != null) { %><input type="hidden" name="max_price" value="<%= maxPrice %>"><% } %>
        <!-- Preserve all color filters through sort changes -->
        <% colorFamilyActive.forEach(function(f) { %><input type="hidden" name="color_family" value="<%= f %>"><% }) %>
        <% colorExactActive.forEach(function(e) { %><input type="hidden" name="color_exact" value="<%= e %>"><% }) %>
        <% hwColorFamilyActive.forEach(function(f) { %><input type="hidden" name="hw_color_family" value="<%= f %>"><% }) %>
        <% hwColorExactActive.forEach(function(e) { %><input type="hidden" name="hw_color_exact" value="<%= e %>"><% }) %>
        <select name="sort" class="sort-select" onchange="this.closest('form').submit()" aria-label="Sort products">
          <option value="featured"   <%= sort==='featured'   ? 'selected':'' %>>Featured</option>
          <option value="newest"     <%= sort==='newest'     ? 'selected':'' %>>Newest</option>
          <option value="price_asc"  <%= sort==='price_asc'  ? 'selected':'' %>>Price: Low to High</option>
          <option value="price_desc" <%= sort==='price_desc' ? 'selected':'' %>>Price: High to Low</option>
          <option value="name_asc"   <%= sort==='name_asc'   ? 'selected':'' %>>Name A–Z</option>
        </select>
      </form>
      <% } /* end: hide sort form for model-group */ %>
    </div>

    <%/*
     * ── Model-group card grid ─────────────────────────────────────────
     * When displayMode === 'model-group', render model cards (one per
     * brand+model group) matching vanity-models.ejs card markup.
     * Image swap on swatch click is handled by existing site.js.
     * Otherwise, fall through to the regular product card grid.
     */%>
    <% if (typeof displayMode !== 'undefined' && displayMode === 'model-group') { %>

    <% if (!models || models.length === 0) { %>
    <div class="listing-empty">
      <p>No models found matching your filters.</p>
      <a href="/collections/<%= category.slug %>" class="btn btn-sage" style="margin-top:16px">Clear Filters</a>
    </div>
    <% } else { %>
    <div class="listing-grid models-grid models-grid--page">
      <% models.forEach(function(m) { %>
      <%
        var _discPct         = m.compare_price_from ? Math.round((1 - m.price_from / m.compare_price_from) * 100) : 0;
        var _visibleSwatches = m.finishes.slice(0, 4);
        var _extraSwatches   = m.finishes.length > 4 ? m.finishes.length - 4 : 0;
        var _mId             = m.model ? m.model.toLowerCase().replace(/[^a-z0-9]+/g, '-') : 'model';
        var _mHref           = '/collections/vanities?model=' + encodeURIComponent(m.model || '');
        // Initial image = first swatch's image so the visual matches the is-active swatch state.
        // Fallback to model-level image if first swatch has none.
        var _mImg = (_visibleSwatches.length > 0 && _visibleSwatches[0].image_url)
          ? _visibleSwatches[0].image_url
          : (m.image_url || '/images/placeholder-vanity.jpg');
      %>
      <article class="model-card" data-model="<%= m.model %>" data-sizes="<%= m.sizes.join(',') %>">

        <div class="model-card-img-wrap">
          <% if (_discPct > 0) { %>
          <span class="model-card-badge"><%= _discPct %>% OFF</span>
          <% } %>
          <a href="<%= _mHref %>" class="model-card-img-link" tabindex="-1" aria-hidden="true">
            <img src="<%= _mImg %>"
                 alt="<%= m.model %> vanity"
                 class="model-card-img"
                 id="model-img-<%= _mId %>"
                 loading="lazy">
          </a>
        </div>

        <div class="model-card-body">
          <h3 class="model-card-name">
            <a href="<%= _mHref %>">The <%= m.model %> Collection</a>
          </h3>
          <p class="model-card-brand">Brand: <%= m.brand %></p>

          <!-- Price — gold color, below brand, above finishes (brand colors rule) -->
          <div class="model-card-price-row">
            <% if (m.price_to && m.price_to > m.price_from) { %>
            <span class="model-card-price">$<%= m.price_from.toLocaleString('en-US') %> – $<%= m.price_to.toLocaleString('en-US') %></span>
            <% } else { %>
            <span class="model-card-price">From $<%= m.price_from.toLocaleString('en-US') %></span>
            <% if (m.compare_price_from) { %>
            <span class="model-card-was">$<%= m.compare_price_from.toLocaleString('en-US') %></span>
            <% } %>
            <% } %>
          </div>

          <div class="model-card-swatches" role="group" aria-label="Available finishes">
            <span class="model-card-swatches-label">Finishes:</span>
            <% _visibleSwatches.forEach(function(f, i) { %>
            <%
              var _isLight      = ['#F0F0EF','#F5F5F5','#FAFAFA','#FFFFFF','#C4A882'].indexOf(f.hex) !== -1;
              var _swatchBorder = _isLight ? '#ccc' : (f.border || f.hex);
              var _isWood       = ['wood_l','wood_m','wood_d'].indexOf(f.color_family) !== -1;
            %>
            <button class="model-card-swatch<%= i === 0 ? ' is-active' : '' %><%= _isWood ? ' swatch--wood-grain' : '' %>"
                    data-target-img="model-img-<%= _mId %>"
                    data-finish="<%= f.color %>"
                    <% if (f.image_url) { %>data-image="<%= f.image_url %>"<% } %>
                    <% if (f.sizeImages && Object.keys(f.sizeImages).length) { %>data-size-images="<%= JSON.stringify(f.sizeImages) %>"<% } %>
                    style="background:<%= f.hex %>;border-color:<%= _swatchBorder %>"
                    aria-label="<%= f.color %>"
                    title="<%= f.color %>"></button>
            <% }); %>
            <% if (_extraSwatches > 0) { %>
            <span class="model-card-swatch-more" aria-hidden="true">+<%= _extraSwatches %></span>
            <% } %>
          </div>

          <div class="model-card-sizes-row">
            <span class="model-card-sizes-label">Sizes:</span>
            <% if (m.sizes && m.sizes.length) { %>
            <div class="model-card-size-chips">
              <% m.sizes.forEach(function(sz, i) {
                   var _szImg = m.sizeImages && m.sizeImages[sz] ? m.sizeImages[sz] : null;
              %>
              <button type="button"
                      class="model-card-size-btn<%= i === 0 ? ' is-active' : '' %>"
                      data-target-img="model-img-<%= _mId %>"
                      data-size="<%= sz %>"
                      <% if (_szImg) { %>data-image="<%= _szImg %>"<% } %>
                      aria-label="<%= sz %>&quot; wide"
                      title="<%= sz %>&quot; wide">
                <%= sz %>"
              </button>
              <% }); %>
            </div>
            <% } else { %>
            <span class="model-card-sizes-text">See details</span>
            <% } %>
          </div>

          <a href="<%= _mHref %>" class="btn btn-outline model-card-cta">Shop Model</a>
        </div>
      </article>
      <% }); %>
    </div><!-- /.listing-grid.models-grid -->

    <!-- Model-group pagination -->
    <% if (pages > 1) { %>
    <nav class="pagination" aria-label="Page navigation">
      <%
        var _mgQs = '';
        (activeSizes  || []).forEach(function(s) { _mgQs += '&size_in='      + encodeURIComponent(s); });
        (activeBrands || []).forEach(function(b) { _mgQs += '&brand='        + encodeURIComponent(b); });
        colorFamilyActive.forEach(function(f)    { _mgQs += '&color_family=' + encodeURIComponent(f); });
        colorExactActive.forEach(function(e)     { _mgQs += '&color_exact='  + encodeURIComponent(e); });
        if (minPrice != null) _mgQs += '&min_price=' + minPrice;
        if (maxPrice != null) _mgQs += '&max_price=' + maxPrice;
      %>
      <% (pageWindow || []).forEach(function(p) { %>
      <% if (p === null) { %>
      <span class="page-ellipsis" aria-hidden="true">&hellip;</span>
      <% } else if (p === page) { %>
      <span class="page-btn page-current" aria-current="page"><%= p %></span>
      <% } else { %>
      <a href="?page=<%= p %><%= _mgQs %>" class="page-btn" aria-label="Page <%= p %>"><%= p %></a>
      <% } %>
      <% }) %>
    </nav>
    <% } %>

    <% } /* end: models.length > 0 */ %>

    <% } else { /* ── Regular product card grid ──────────────────── */ %>

    <% if (products.length === 0) { %>
    <div class="listing-empty">
      <p>No products found matching your filters.</p>
      <a href="/collections/<%= category.slug %>" class="btn btn-sage" style="margin-top:16px">Clear Filters</a>
    </div>
    <% } else { %>
    <div class="listing-grid">
      <% products.forEach(function(product) { %>
      <%
        /* DB-driven model color swatches */
        var _pImgId       = 'prod-img-' + product.id;
        var _mcSwatches   = (product.model && typeof modelColorMap !== 'undefined' && modelColorMap[product.model])
                              ? modelColorMap[product.model] : [];
        /* Fallback: if no model swatches, show single swatch for this product's own color */
        if (!_mcSwatches.length && product.color_family && typeof familyHex !== 'undefined') {
          _mcSwatches = [{
            color:        product.color || '',
            color_family: product.color_family,
            hex:          familyHex[product.color_family]               || '#ccc',
            border:       familyHex[product.color_family + '_border']   || '#aaa',
          }];
        }
        var _pSwatches    = _mcSwatches.slice(0, 4);
        var _pSwatchExtra = _mcSwatches.length > 4 ? _mcSwatches.length - 4 : 0;
        var _pSizes       = (product.model && typeof modelSizeMap !== 'undefined' && modelSizeMap[product.model])
                              ? modelSizeMap[product.model] : null;
      %>
      <article class="product-card">
        <a href="/products/<%= product.slug %>" class="product-img-link" aria-label="<%= product.name %>">
          <div class="product-img">
            <% if (product.primary_image) { %>
              <img src="<%= product.primary_image %>" alt="<%= product.name %>" loading="lazy"
                   id="<%= _pImgId %>">
            <% } else { %>
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" aria-hidden="true">
                <rect x="3" y="3" width="18" height="18" rx="2"/>
                <circle cx="8.5" cy="8.5" r="1.5"/>
                <polyline points="21 15 16 10 5 21"/>
              </svg>
            <% } %>
            <% if (product.badge) { %>
            <span class="product-badge badge-<%= product.badge %>"><%= product.badge.toUpperCase() %></span>
            <% } %>
            <!-- Heart / Favorites button -->
            <button class="heart-btn<%= (typeof savedProductIds !== 'undefined' && savedProductIds.has(product.id)) ? ' is-saved' : '' %>"
                    data-product-id="<%= product.id %>"
                    data-product-slug="<%= product.slug %>"
                    aria-label="Save to favorites"
                    type="button">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
              </svg>
            </button>
          </div>
        </a>
        <div class="product-body">
          <% if (product.brand) { %><p class="product-brand"><%= product.brand %></p><% } %>
          <h3 class="product-title">
            <a href="/products/<%= product.slug %>"><%= product.name %></a>
          </h3>

          <!-- Price — Option B: Gold sale, Navy/Amber-strikethrough was-price (approved July 2026) -->
          <% if (product.price) { %>
          <%   var _onSale = product.compare_price && parseFloat(product.compare_price) > parseFloat(product.price); %>
          <div class="card-price">
            <% if (_onSale) { %>
              <span class="card-price__sale">$<%= parseFloat(product.price).toLocaleString('en-US', {minimumFractionDigits:0, maximumFractionDigits:0}) %></span>
              <span class="card-price__was">$<%= parseFloat(product.compare_price).toLocaleString('en-US', {minimumFractionDigits:0, maximumFractionDigits:0}) %></span>
            <% } else { %>
              <span class="card-price__regular">$<%= parseFloat(product.price).toLocaleString('en-US', {minimumFractionDigits:0, maximumFractionDigits:0}) %></span>
            <% } %>
          </div>
          <% } %>

          <!-- Finishes -->
          <div class="model-card-swatches" role="group" aria-label="Available finishes">
            <span class="model-card-swatches-label">Finishes:</span>
            <% if (_pSwatches.length) { %>
              <% _pSwatches.forEach(function(f, i) { %>
              <%
                var _isLight = f.hex && ['#f5f5f3','#f0f0ef','#f5f5f5','#fafafa','#ffffff','#e8d9b8'].indexOf(f.hex.toLowerCase()) !== -1;
                var _sb      = _isLight ? '#ccc' : (f.border || f.hex);
                var _isWood  = ['wood_l','wood_m','wood_d'].indexOf(f.color_family) !== -1;
              %>
              <button class="model-card-swatch<%= i === 0 ? ' is-active' : '' %><%= _isWood ? ' swatch--wood-grain' : '' %>"
                      data-target-img="<%= _pImgId %>"
                      data-finish="<%= f.color %>"
                      <% if (f.image_url) { %>data-image="<%= f.image_url %>"<% } %>
                      style="background:<%= f.hex %>;border-color:<%= _sb %>"
                      aria-label="<%= f.color %>"
                      title="<%= f.color %>"></button>
              <% }); %>
              <% if (_pSwatchExtra > 0) { %>
              <span class="model-card-swatch-more" aria-hidden="true">+<%= _pSwatchExtra %></span>
              <% } %>
            <% } else { %>
            <span class="model-card-sizes-text">See details</span>
            <% } %>
          </div>

          <!-- Size Options -->
          <div class="model-card-sizes-row">
            <span class="model-card-sizes-label">Size Options:</span>
            <% if (_pSizes && _pSizes.length) { %>
            <span class="model-card-sizes-text"><%= _pSizes.join(' | ') %></span>
            <% } else { %>
            <span class="model-card-sizes-text">See details</span>
            <% } %>
          </div>

          <a href="/products/<%= product.slug %>" class="btn btn-sage">View Details</a>
        </div>
      </article>
      <% }) %>
    </div>

    <!-- Pagination -->
    <% if (pages > 1) { %>
    <nav class="pagination" aria-label="Page navigation">
      <%
        /* Build base query string preserving all active filters */
        var filterQs = '';
        brands.forEach(function(b) { filterQs += '&brand=' + encodeURIComponent(b); });
        productTypes.forEach(function(t) { filterQs += '&type=' + encodeURIComponent(t); });
        Object.entries(attrFilters).forEach(function(entry) {
          entry[1].forEach(function(v) { filterQs += '&' + entry[0] + '=' + encodeURIComponent(v); });
        });
        Object.entries(rangeFilters).forEach(function(entry) {
          var key = entry[0], range = entry[1];
          if (range.min != null) filterQs += '&' + key + '_min=' + range.min;
          if (range.max != null) filterQs += '&' + key + '_max=' + range.max;
        });
        if (minPrice != null) filterQs += '&min_price=' + minPrice;
        if (maxPrice != null) filterQs += '&max_price=' + maxPrice;
        colorFamilyActive.forEach(function(f) { filterQs += '&color_family=' + encodeURIComponent(f); });
        colorExactActive.forEach(function(e) { filterQs += '&color_exact=' + encodeURIComponent(e); });
        hwColorFamilyActive.forEach(function(f) { filterQs += '&hw_color_family=' + encodeURIComponent(f); });
        hwColorExactActive.forEach(function(e) { filterQs += '&hw_color_exact=' + encodeURIComponent(e); });
      %>
      <% (pageWindow || []).forEach(function(p) { %>
      <% if (p === null) { %>
      <span class="page-ellipsis" aria-hidden="true">&hellip;</span>
      <% } else if (p === page) { %>
      <span class="page-btn page-current" aria-current="page"><%= p %></span>
      <% } else { %>
      <a href="?page=<%= p %>&sort=<%= sort %><%= filterQs %>"
         class="page-btn"
         aria-label="Page <%= p %>">
        <%= p %>
      </a>
      <% } %>
      <% }) %>
    </nav>
    <% } %>
    <% } /* end: products.length > 0 */ %>

    <% } /* end: displayMode !== 'model-group' regular product grid */ %>

  </div><!-- /listing-main -->
</div><!-- /listing-layout -->
