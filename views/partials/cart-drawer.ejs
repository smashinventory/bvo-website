<%
const _cd  = (settings && settings.cart_drawer) ? settings.cart_drawer : {};
const _gl  = (settings && settings.global)      ? settings.global      : {};
const _threshold = parseFloat(_cd.free_shipping_threshold || _gl.free_shipping_threshold || 0);
const _cartItems = (typeof cart !== 'undefined' && cart) ? cart : { items: [], count: 0, total: 0 };
const _total     = parseFloat(_cartItems.total || 0);
const _remaining = Math.max(0, _threshold - _total);
const _pct       = _threshold > 0 ? Math.min(100, Math.round((_total / _threshold) * 100)) : 100;
%>

<!-- Cart Drawer Overlay -->
<div class="cd-overlay" id="cdOverlay" aria-hidden="true"></div>

<!-- Cart Drawer Panel -->
<aside class="cart-drawer" id="cartDrawer" aria-label="Shopping cart" aria-hidden="true" inert>

  <!-- Header -->
  <div class="cd-header">
    <h2 class="cd-title">
      Your Cart
      <% if (_cartItems.count > 0) { %>
      <span class="cd-count"><%= _cartItems.count %></span>
      <% } %>
    </h2>
    <button class="cd-close" id="cdClose" aria-label="Close cart">
      <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" fill="none" stroke-width="2">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>

  <!-- Free Shipping Progress Bar -->
  <% if (_threshold > 0) { %>
  <div class="cd-shipping-bar">
    <% if (_remaining <= 0) { %>
    <p class="cd-shipping-msg cd-shipping-done"><%- _cd.free_shipping_message || '🎉 You qualify for FREE shipping!' %></p>
    <% } else { %>
    <p class="cd-shipping-msg"><%- (_cd.progress_message || 'Add <strong>${{remaining}}</strong> more for free shipping').replace('{{remaining}}', _remaining.toFixed(2)) %></p>
    <% } %>
    <div class="cd-bar-track"><div class="cd-bar-fill" style="width:<%= _pct %>%"></div></div>
  </div>
  <% } %>

  <!-- Cart Items -->
  <div class="cd-body">
    <% if (!_cartItems.items || _cartItems.items.length === 0) { %>
    <div class="cd-empty">
      <svg viewBox="0 0 24 24" width="48" height="48" stroke="currentColor" fill="none" stroke-width="1" aria-hidden="true">
        <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/>
      </svg>
      <p><%= _cd.empty_message || 'Your cart is empty' %></p>
      <a href="<%= _cd.empty_cta_url || '/collections/bathroom-vanities' %>" class="btn btn-sage cd-empty-cta"><%= _cd.empty_cta_text || 'Start Shopping' %></a>
    </div>
    <% } else { %>
    <ul class="cd-items" role="list">
      <% _cartItems.items.forEach(item => { %>
      <li class="cd-item">
        <div class="cd-item-img">
          <% if (item.image) { %>
          <img src="<%= item.image %>" alt="<%= item.name %>" loading="lazy">
          <% } else { %>
          <div class="cd-item-img-placeholder">
            <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" fill="none" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
          </div>
          <% } %>
        </div>
        <div class="cd-item-info">
          <p class="cd-item-name"><%= item.name %></p>
          <p class="cd-item-price">$<%= parseFloat(item.price).toFixed(2) %> × <%= item.qty %></p>
        </div>
        <div class="cd-item-controls">
          <form action="/cart/update" method="POST" class="cd-qty-form">
            <input type="hidden" name="productId" value="<%= item.productId %>">
            <button type="button" class="cd-qty-btn" data-action="decrease" data-id="<%= item.productId %>">−</button>
            <span class="cd-qty-val"><%= item.qty %></span>
            <button type="button" class="cd-qty-btn" data-action="increase" data-id="<%= item.productId %>">+</button>
          </form>
          <form action="/cart/remove" method="POST" class="cd-remove-form">
            <input type="hidden" name="productId" value="<%= item.productId %>">
            <button type="submit" class="cd-remove-btn" aria-label="Remove">
              <svg viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" fill="none" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>
            </button>
          </form>
        </div>
      </li>
      <% }) %>
    </ul>
    <% } %>
  </div>

  <!-- Footer -->
  <% if (_cartItems.items && _cartItems.items.length > 0) { %>
  <div class="cd-footer">
    <div class="cd-subtotal">
      <span>Subtotal</span>
      <strong>$<%= _total.toFixed(2) %></strong>
    </div>
    <p class="cd-tax-note">Taxes and shipping calculated at checkout</p>
    <a href="/cart" class="btn btn-navy cd-checkout-btn">View Cart & Checkout →</a>
  </div>
  <% } %>

</aside>
