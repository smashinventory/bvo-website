<% const S = settings || {}; const ps = S.promo_strip || {}; const nav = S.nav || {}; %>

<!-- ── Promo strip ──────────────────────────────────────────────── -->
<% if (ps.enabled !== false) { %>
<div class="promo-strip" role="banner" aria-label="Promotional announcement">
  <%= ps.message || 'Free Shipping on Every Order' %>
  <% if (ps.link_url && ps.link_text) { %>
  &nbsp;·&nbsp; <a href="<%= ps.link_url %>"><strong><%= ps.link_text %> →</strong></a>
  <% } %>
</div>
<% } %>

<!-- ── Site navigation ──────────────────────────────────────────── -->
<header class="site-header">
  <nav class="site-nav" aria-label="Main navigation">

    <!-- Logo (never regenerated — locked asset) -->
    <a href="/" class="nav-logo-link" aria-label="<%= (S.global || {}).site_name || 'BathroomVanitiesOutlet.com' %> — Home">
      <img
        class="nav-logo"
        src="/images/logos/BVOLOGOSQ_512.png"
        alt="<%= (S.global || {}).site_name || 'BathroomVanitiesOutlet.com' %> logo"
        width="90"
        height="90"
        loading="eager"
      >
    </a>

    <!-- Brand name -->
    <a href="/" class="nav-brand" aria-hidden="true">
      <%= nav.brand_line1 || 'BathroomVanities' %><span><%= nav.brand_line2 || 'Outlet' %></span><%= nav.brand_line3 || '.com' %>
    </a>

    <!-- Primary links -->
    <ul class="nav-links" role="list">
      <% (nav.links || []).forEach(link => { %>
      <% if (link.megaMenu) { %>
      <li class="has-mega">
        <a href="<%= link.url %>" class="nav-mega-trigger" aria-haspopup="true" aria-expanded="false">
          <%= link.label %>
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
        </a>
        <div class="mega-menu" role="navigation" aria-label="<%= link.label %> menu">
          <!-- Left col: functional + size tracks -->
          <div class="mega-col mega-col--links">
            <div class="mega-section">
              <p class="mega-heading">Shop By Type</p>
              <a class="mega-link" href="/collections/vanities?type=Single+Sink+Vanity">Single Sink Vanity</a>
              <a class="mega-link" href="/collections/vanities?type=Double+Sink+Vanity">Double Sink Vanity</a>
              <a class="mega-link" href="/collections/vanities?type=Vanity+With+Storage">Vanity With Storage</a>
              <a class="mega-link" href="/collections/vanities?type=Base+Cabinet">Base Cabinet</a>
            </div>
            <div class="mega-section">
              <p class="mega-heading">Shop By Size</p>
              <div class="mega-sizes">
                <a class="mega-size-chip" href="/collections/vanities?size_in=30">30"</a>
                <a class="mega-size-chip" href="/collections/vanities?size_in=36">36"</a>
                <a class="mega-size-chip" href="/collections/vanities?size_in=42">42"</a>
                <a class="mega-size-chip" href="/collections/vanities?size_in=48">48"</a>
                <a class="mega-size-chip" href="/collections/vanities?size_in=60">60"</a>
                <a class="mega-size-chip" href="/collections/vanities?size_in=72">72"</a>
              </div>
            </div>
          </div>
          <!-- Right col: collections promo panel -->
          <div class="mega-col mega-col--promo">
            <a href="/collections/vanity-models" class="mega-promo-card">
              <p class="mega-promo-eyebrow">Our Collection</p>
              <p class="mega-promo-title">Every Model,<br>Every Finish</p>
              <p class="mega-promo-sub">Browse all vanity collections, sizes, and styles at a glance.</p>
              <span class="mega-promo-cta">Browse All Collections &rarr;</span>
            </a>
          </div>
        </div>
      </li>
      <% } else { %>
      <li><a href="<%= link.url %>"<%= link.highlight ? ' class="nav-link-sale"' : '' %>><%= link.label %></a></li>
      <% } %>
      <% }) %>
    </ul>

    <!-- Icon group: search · account · cart -->
    <div class="nav-icons" aria-label="Site utilities">

      <button class="nav-icon-btn" aria-label="Open search" aria-expanded="false"
              aria-controls="site-search-bar" id="nav-search-btn">
        <svg class="nav-icon" viewBox="0 0 24 24" aria-hidden="true">
          <circle cx="11" cy="11" r="7"/><line x1="16.5" y1="16.5" x2="22" y2="22"/>
        </svg>
      </button>

      <a href="/account" class="nav-icon-btn" aria-label="My account">
        <svg class="nav-icon" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
        </svg>
      </a>

      <a href="/account/favorites" class="nav-icon-btn nav-favorites-btn" aria-label="Saved items">
        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
        </svg>
      </a>

      <a href="/cart" class="nav-icon-btn nav-cart-wrap" aria-label="Shopping cart (<%= cart.count %> items)">
        <svg class="nav-icon" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/>
        </svg>
        <% if (cart.count > 0) { %>
        <span class="nav-cart-badge" aria-hidden="true"><%= cart.count %></span>
        <% } %>
      </a>

    </div>

    <button class="nav-hamburger" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
      <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" fill="none" stroke-width="2" aria-hidden="true">
        <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>

  </nav>

  <!-- ── Search bar (hidden until icon click) ────────────────────── -->
  <div class="site-search" id="site-search-bar" role="search" aria-label="Search products">
    <div class="site-search-inner">
      <label for="search-input" class="sr-only">Search products</label>
      <svg class="site-search-icon" viewBox="0 0 24 24" width="18" height="18" fill="none"
        stroke="currentColor" stroke-width="2" aria-hidden="true">
        <circle cx="11" cy="11" r="7"/><line x1="16.5" y1="16.5" x2="22" y2="22"/>
      </svg>
      <input
        id="search-input"
        type="search"
        name="q"
        placeholder="Search vanities, faucets, mirrors…"
        autocomplete="off"
        spellcheck="false"
        aria-label="Search products"
        aria-controls="search-results"
        aria-autocomplete="list"
      >
      <div id="search-results" class="search-results-wrap" hidden role="listbox" aria-label="Search suggestions"></div>
    </div>
  </div>

  <!-- Mobile drawer -->
  <div id="mobile-menu" class="mobile-menu" aria-hidden="true">
    <ul role="list">
      <% (nav.links || []).forEach(link => { %>
      <li><a href="<%= link.url %>"<%= link.highlight ? ' class="nav-link-sale"' : '' %>><%= link.label %></a></li>
      <% if (link.megaMenu) { %>
      <li class="mobile-sub"><a href="/collections/vanities?type=Single+Sink+Vanity">Single Sink</a></li>
      <li class="mobile-sub"><a href="/collections/vanities?type=Double+Sink+Vanity">Double Sink</a></li>
      <li class="mobile-sub"><a href="/collections/vanities?type=Vanity+With+Storage">With Storage</a></li>
      <li class="mobile-sub"><a href="/collections/vanities?type=Base+Cabinet">Base Cabinet</a></li>
      <li class="mobile-sub"><a href="/collections/vanity-models">Browse All Collections</a></li>
      <% } %>
      <% }) %>
      <li><a href="/account">My Account</a></li>
      <li><a href="/account/favorites">Saved Items</a></li>
      <li><a href="/cart">Cart (<%= cart.count %>)</a></li>
    </ul>
  </div>

</header>
