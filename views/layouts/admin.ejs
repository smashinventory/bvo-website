<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle %></title>

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600&family=Lato:wght@300;400;700;900&display=swap" rel="stylesheet">

  <!-- Brand tokens -->
  <link rel="stylesheet" href="/css/brand.css">
  <!-- Admin CSS (appended to site.css) -->
  <link rel="stylesheet" href="/css/site.css">

  <%- style %>
</head>
<body class="admin-body">

  <div class="admin-shell">

    <!-- Sidebar -->
    <aside class="admin-sidebar" id="adminSidebar">
      <div class="admin-sidebar-header">
        <a href="/admin" class="admin-logo-link">
          <img src="/images/logos/BVOLOGOSQ_512.png" alt="BVO" width="40" height="40" class="admin-logo">
        </a>
        <div class="admin-brand">
          <span class="admin-brand-name">BVO</span>
          <span class="admin-brand-sub">Admin</span>
        </div>
      </div>

      <nav class="admin-nav" aria-label="Admin navigation">
        <a href="/admin" class="admin-nav-item <%= (typeof activePage !== 'undefined' && activePage === 'dashboard') ? 'active' : '' %>">
          <svg viewBox="0 0 24 24" class="admin-nav-icon"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          Dashboard
        </a>
        <a href="/admin/products" class="admin-nav-item <%= (typeof activePage !== 'undefined' && activePage === 'products') ? 'active' : '' %>">
          <svg viewBox="0 0 24 24" class="admin-nav-icon"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          Products
        </a>
        <a href="/admin/categories" class="admin-nav-item <%= (typeof activePage !== 'undefined' && activePage === 'categories') ? 'active' : '' %>">
          <svg viewBox="0 0 24 24" class="admin-nav-icon"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
          Categories
        </a>
        <a href="/admin/orders" class="admin-nav-item <%= (typeof activePage !== 'undefined' && activePage === 'orders') ? 'active' : '' %>">
          <svg viewBox="0 0 24 24" class="admin-nav-icon"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
          Orders
        </a>
        <a href="/admin/customers" class="admin-nav-item <%= (typeof activePage !== 'undefined' && activePage === 'customers') ? 'active' : '' %> admin-nav-disabled" aria-disabled="true">
          <svg viewBox="0 0 24 24" class="admin-nav-icon"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          Customers <span class="admin-nav-soon">soon</span>
        </a>
        <a href="/admin/theme" class="admin-nav-item <%= (typeof activePage !== 'undefined' && activePage === 'theme') ? 'active' : '' %>">
          <svg viewBox="0 0 24 24" class="admin-nav-icon"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
          Theme Editor
        </a>
        <a href="/admin/sync" class="admin-nav-item <%= (typeof activePage !== 'undefined' && activePage === 'sync') ? 'active' : '' %>">
          <svg viewBox="0 0 24 24" class="admin-nav-icon" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
          RFLPOS Sync
        </a>
        <a href="/admin/products/color-report" class="admin-nav-item <%= (typeof activePage !== 'undefined' && activePage === 'color-report') ? 'active' : '' %>">
          <svg viewBox="0 0 24 24" class="admin-nav-icon" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="4"/><line x1="4.93" y1="4.93" x2="9.17" y2="9.17"/><line x1="14.83" y1="14.83" x2="19.07" y2="19.07"/><line x1="14.83" y1="9.17" x2="19.07" y2="4.93"/><line x1="4.93" y1="19.07" x2="9.17" y2="14.83"/></svg>
          Color Report
        </a>
      </nav>

      <div class="admin-sidebar-footer">
        <a href="/" target="_blank" class="admin-footer-link">
          <svg viewBox="0 0 24 24" class="admin-nav-icon"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          View Store
        </a>
        <form action="/admin/logout" method="POST">
          <button type="submit" class="admin-footer-link admin-signout-btn">
            <svg viewBox="0 0 24 24" class="admin-nav-icon"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
            Sign Out
          </button>
        </form>
      </div>
    </aside>

    <!-- Main content area -->
    <div class="admin-main">
      <header class="admin-topbar">
        <button class="admin-menu-toggle" id="adminMenuToggle" aria-label="Toggle sidebar">
          <svg viewBox="0 0 24 24" width="22" height="22" stroke="currentColor" fill="none" stroke-width="2"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        </button>
        <span class="admin-topbar-title"><%= pageTitle %></span>
        <div class="admin-topbar-user">
          <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" fill="none" stroke-width="1.8"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
          Admin
        </div>
      </header>

      <div class="admin-content">
        <% if (typeof flash !== 'undefined' && flash) { %>
        <div class="admin-flash admin-flash-<%= flash.type %>"><%= flash.msg %></div>
        <% } %>

        <%- body %>
      </div>
    </div>

  </div><!-- /.admin-shell -->

  <script src="/js/site.js"></script>
  <script>
    // Sidebar toggle (mobile)
    document.getElementById('adminMenuToggle')?.addEventListener('click', () => {
      document.getElementById('adminSidebar').classList.toggle('open');
    });
  </script>
  <%- script %>

</body>
</html>
