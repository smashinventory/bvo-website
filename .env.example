# ── Server ──────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
SESSION_SECRET=change-this-to-a-long-random-string

# ── Website Database (Hostinger MySQL) ──────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=bvo_website
DB_USER=bvo_user
DB_PASS=your_password

# ── RFLPOS Sync ─────────────────────────────────────────────────
RFLPOS_DB_HOST=your_rflpos_host
RFLPOS_DB_PORT=3306
RFLPOS_DB_NAME=rflpos_db
RFLPOS_DB_USER=rflpos_readonly_user
RFLPOS_DB_PASS=your_password
RFLPOS_WEBHOOK_SECRET=your_webhook_secret

# ── Salsify (James Martin + API suppliers) ───────────────────────
SALSIFY_API_KEY=your_salsify_api_key
SALSIFY_ORG_ID=your_org_id

# ── Email (Nodemailer) ───────────────────────────────────────────
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=info@bathroomvanitiesoutlet.com
SMTP_PASS=your_email_password

# ── Site URL (used for canonical tags, sitemap, JSON-LD) ─────────
SITE_URL=https://bathroomvanitiesoutlet.com

# ── Analytics / Marketing ────────────────────────────────────────
GA4_ID=G-PLBNP2YD9K
GTM_ID=GTM-XXXXXXX
GMC_MERCHANT_ID=311582550

# ── Live Chat (Tidio) ────────────────────────────────────────────
# Get your Public Key: Tidio dashboard → Settings → Installation
TIDIO_PUBLIC_KEY=your_tidio_public_key

# ── Typesense Search ─────────────────────────────────────────────
# Cloud: https://cloud.typesense.org → create cluster → copy credentials
TYPESENSE_HOST=xxx.a1.typesense.net
TYPESENSE_PORT=443
TYPESENSE_PROTOCOL=https
TYPESENSE_API_KEY=your_admin_api_key
# After setting up, run: node src/jobs/searchSync.js
# Delta sync cron (every 15 min): */15 * * * * node .../searchSync.js --delta

# ── Admin ────────────────────────────────────────────────────────
ADMIN_EMAIL=global.value.supply@gmail.com
